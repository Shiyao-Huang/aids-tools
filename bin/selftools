#!/usr/bin/env python3
"""AIDS (Agent-ID System): identity-aware trace CLI and hook handler.

No third-party dependencies. The filesystem is the database:
  ~/.aids/sessions/{session_id}.json
  ~/.aids/traces/YYYY-MM-DD.jsonl
  ~/.aids/timeline/YYYY-MM-DD.jsonl
  ~/.aids/index/{base64(resource)}.json
  ~/.aids/ratings/YYYY-MM-DD.jsonl

Legacy aliases (selftools, AID_*, ZHUYI_*, ~/.zhuyi) remain readable during
migration, but the public name is AIDS and new installs write under ~/.aids.
"""
from __future__ import annotations

import argparse
import ast as _ast
import base64
import csv
import datetime as _dt
import hashlib
import io
import json
import os
import re
import shutil
import shlex
import socket
import subprocess
import sys
import time
import uuid
import warnings
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Tuple

try:
    import fcntl  # type: ignore
except Exception:  # pragma: no cover - Windows fallback
    fcntl = None  # type: ignore

APP = "aids"
ZH_NAME = "AIDS (Agent-ID System)"


def env_first(*names: str) -> Optional[str]:
    for name in names:
        value = os.environ.get(name)
        if value:
            return value
    return None


DEFAULT_DATA_DIR = Path(env_first("AIDS_DATA_DIR", "AIDS_HOME", "AID_DATA_DIR", "AID_HOME", "SELFTOOLS_DATA_DIR", "SELFTOOLS_HOME", "CONSCIOUS_TOOLS_HOME", "ZHUYI_DATA_DIR", "ZHUYI_HOME") or "~/.aids").expanduser()
RECENT_LIMIT = int(env_first("AIDS_RECENT_LIMIT", "AID_RECENT_LIMIT", "SELFTOOLS_RECENT_LIMIT", "ZHUYI_RECENT_LIMIT") or "5")

WRITE_TOOL_NAMES = {"Write", "Edit", "MultiEdit", "NotebookEdit", "apply_patch"}
READ_TOOL_NAMES = {"Read"}
TRACE_TOOL_NAMES = WRITE_TOOL_NAMES | READ_TOOL_NAMES | {"Bash"}


def now_ms() -> int:
    return int(time.time() * 1000)


def iso_now() -> str:
    return _dt.datetime.now(_dt.timezone.utc).isoformat()


def today() -> str:
    return _dt.datetime.now().strftime("%Y-%m-%d")


def data_dir() -> Path:
    return DEFAULT_DATA_DIR


def ensure_layout() -> None:
    for rel in ["sessions", "traces", "timeline", "index", "ratings", "pending", "locks", "logs", "codegraph"]:
        (data_dir() / rel).mkdir(parents=True, exist_ok=True)
    clean_all_stale_locks()


def eprint(*args: Any) -> None:
    print(*args, file=sys.stderr)


def current_session_id() -> Optional[str]:
    """Return the current session ID from environment, or None."""
    return env_first("AIDS_SESSION_ID", "AID_SESSION_ID", "SESSION_ID", "SELFTOOLS_SESSION_ID", "ZHUYI_SESSION_ID", "AHA_SESSION_ID")


def identity_stamp() -> str:
    """Return a compact identity prefix like '[sid role display_name]' for error/caption output."""
    sid = current_session_id()
    if not sid:
        return ""
    role = env_first("AIDS_ROLE", "AID_ROLE", "AHA_AGENT_ROLE", "ROLE", "SELFTOOLS_ROLE", "ZHUYI_ROLE", "AHA_ROLE") or "?"
    name = env_first("AIDS_DISPLAY_NAME", "AHA_SESSION_NAME", "AID_DISPLAY_NAME", "SELFTOOLS_DISPLAY_NAME", "ZHUYI_DISPLAY_NAME") or sid[:8]
    return f"[{sid[:8]} {role} {short(name, 20)}]"


def eprint_identity(*args: Any) -> None:
    """Print to stderr with identity prefix when available."""
    stamp = identity_stamp()
    if stamp:
        print(stamp, *args, file=sys.stderr)
    else:
        print(*args, file=sys.stderr)


def write_identity_files(session: Dict[str, Any]) -> None:
    """Write self-reference files: .current symlink, .identity, AIDS_IDENTITY.md."""
    dd = data_dir()
    sid = session.get("session_id", "unknown")

    # ── ~/.aids/.identity — plain text quick-read ──
    identity_file = dd / ".identity"
    lines = [
        f"session_id: {sid}",
        f"role:        {session.get('role', '?')}",
        f"runtime:     {session.get('runtime', '?')}",
        f"display:     {session.get('display_name', sid)}",
        f"goal:        {session.get('goal', '')}",
        f"team_id:     {session.get('team_id', '')}",
        f"task_id:     {session.get('task_id', '')}",
        f"project:     {session.get('project_path', '')}",
        f"status:      {session.get('status', 'active')}",
        f"started_at:  {session.get('started_iso', '')}",
    ]
    try:
        identity_file.write_text("\n".join(lines) + "\n", encoding="utf-8")
    except OSError:
        pass

    # ── ~/.aids/sessions/.current → symlink to active session JSON ──
    current_link = dd / "sessions" / ".current"
    target = session_path(sid)
    try:
        if current_link.is_symlink():
            current_link.unlink()
        elif current_link.exists():
            current_link.unlink()
        current_link.symlink_to(str(target))
    except OSError:
        pass

    # ── .claude/AIDS_IDENTITY.md — injected into Claude's context ──
    project = session.get("project_path") or os.getcwd()
    claude_dir = Path(project) / ".claude"
    try:
        claude_dir.mkdir(parents=True, exist_ok=True)
        identity_md = claude_dir / "AIDS_IDENTITY.md"
        md_lines = [
            f"# AIDS Agent Identity",
            f"",
            f"- **Session**: `{sid}`",
            f"- **Role**: {session.get('role', '?')}",
            f"- **Runtime**: {session.get('runtime', '?')}",
            f"- **Display Name**: {session.get('display_name', sid)}",
            f"- **Goal**: {session.get('goal', '(none)')}",
            f"- **Team**: {session.get('team_id', '(none)')}",
            f"- **Task**: {session.get('task_id', '(none)')}",
            f"- **Project**: {project}",
            f"- **Status**: {session.get('status', 'active')}",
            f"",
            f"_Auto-generated by AIDS SessionStart hook. Do not edit manually._",
        ]
        identity_md.write_text("\n".join(md_lines) + "\n", encoding="utf-8")
    except OSError:
        pass


def read_stdin_json() -> Dict[str, Any]:
    raw = sys.stdin.read()
    if not raw.strip():
        return {}
    try:
        return json.loads(raw)
    except json.JSONDecodeError as exc:
        # Hooks should never crash the host runtime over malformed input.
        append_log({"level": "error", "event": "bad_hook_json", "error": str(exc), "raw_prefix": raw[:500]})
        return {"_raw": raw, "_error": str(exc)}


def append_log(record: Dict[str, Any]) -> None:
    try:
        ensure_layout()
        record.setdefault("timestamp", now_ms())
        record.setdefault("ts", iso_now())
        path = data_dir() / "logs" / f"{today()}.jsonl"
        append_jsonl(path, record)
    except Exception:
        pass


def json_dump(obj: Any) -> str:
    return json.dumps(obj, ensure_ascii=False, indent=2, sort_keys=True)


def json_line(obj: Any) -> str:
    return json.dumps(obj, ensure_ascii=False, separators=(",", ":"))


def write_json_atomic(path: Path, obj: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + f".{os.getpid()}.tmp")
    tmp.write_text(json_dump(obj) + "\n", encoding="utf-8")
    os.replace(tmp, path)


def read_json(path: Path, default: Any = None) -> Any:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return default
    except json.JSONDecodeError:
        return default


class FileLock:
    """File-based lock with stale detection, timeout, and cross-platform support.

    Lock files store PID + timestamp for stale-holder detection.
    Uses fcntl.flock on Unix; os.rename() atomicity as pseudo-lock on non-fcntl.
    Validates lock paths reside under ~/.aids/locks/ to prevent traversal.
    """

    STALE_SECONDS = 300  # 5 minutes

    def __init__(self, path: Path, timeout: float = 5.0):
        self.path = Path(path)
        self.timeout = timeout
        self.fd: Optional[Any] = None
        self._owns_lock: bool = False

    # ── path validation ──

    def _validate_path(self) -> None:
        """Prevent path traversal — lock must live under the locks directory."""
        locks_dir = (data_dir() / "locks").resolve()
        try:
            self.path.resolve().relative_to(locks_dir)
        except ValueError:
            raise ValueError(
                f"Lock path escapes locks directory: {self.path.resolve()}"
            )

    # ── PID-based stale detection ──

    @staticmethod
    def _is_pid_alive(pid: int) -> bool:
        """Check whether *pid* is still running (signal 0 probe)."""
        try:
            os.kill(pid, 0)
            return True
        except (OSError, ProcessLookupError):
            return False

    def _read_lock_info(self) -> Optional[Dict[str, Any]]:
        """Read PID/timestamp metadata from an existing lock file."""
        try:
            text = self.path.read_text(encoding="utf-8").strip()
            if text:
                return json.loads(text)
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            pass
        return None

    def _write_lock_info(self) -> None:
        """Write current PID + timestamp to the lock file via *self.fd*."""
        if self.fd is not None:
            self.fd.seek(0)
            self.fd.truncate()
            self.fd.write(json_line({"pid": os.getpid(), "ts": now_ms()}) + "\n")
            self.fd.flush()

    def _break_stale_lock(self) -> bool:
        """Remove lock file if the holder process is dead.

        Returns True if the lock was stale (or absent), False if holder is alive.
        """
        info = self._read_lock_info()
        if info is None:
            return True
        pid = info.get("pid")
        if not isinstance(pid, int) or pid <= 0:
            return True
        if not self._is_pid_alive(pid):
            try:
                self.path.unlink()
            except FileNotFoundError:
                pass
            return True
        return False

    def _clean_stale_mtime(self) -> None:
        """Fallback: remove lock files older than STALE_SECONDS (mtime-based)."""
        try:
            if self.path.exists():
                age = time.time() - self.path.stat().st_mtime
                if age > self.STALE_SECONDS:
                    self.path.unlink(missing_ok=True)
        except OSError:
            pass

    # ── non-blocking acquire ──

    def _try_acquire_fcntl_nb(self) -> bool:
        """Non-blocking fcntl.flock(LOCK_EX | LOCK_NB). Returns True on success."""
        if self.fd is None:
            self.fd = open(self.path, "a+", encoding="utf-8")
        try:
            fcntl.flock(self.fd.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
            self._owns_lock = True
            self._write_lock_info()
            return True
        except (OSError, IOError):
            return False

    def _try_acquire_rename(self) -> bool:
        """Non-fcntl fallback: atomic lock via os.rename().

        Writes PID metadata to a temp file, then atomically renames it to the
        lock path.  On Windows os.rename() fails if the target exists, giving
        us an exclusive lock without fcntl/msvcrt.
        """
        tmp = self.path.with_suffix(f".tmp.{os.getpid()}")
        try:
            tmp.write_text(
                json_line({"pid": os.getpid(), "ts": now_ms()}) + "\n",
                encoding="utf-8",
            )
            os.rename(tmp, self.path)
            self.fd = open(self.path, "r+", encoding="utf-8")
            self._owns_lock = True
            return True
        except OSError:
            try:
                tmp.unlink()
            except FileNotFoundError:
                pass
            return False

    def _try_acquire_nb(self) -> bool:
        """Non-blocking acquire (fcntl or rename depending on platform)."""
        if fcntl is not None:
            return self._try_acquire_fcntl_nb()
        return self._try_acquire_rename()

    # ── public API ──

    def acquire_with_timeout(self, timeout: float = 30.0) -> "FileLock":
        """Acquire lock with *timeout* seconds. Breaks stale locks from dead holders.

        Polls at ~0.5 s intervals. On timeout, performs one last stale-check
        before raising ``TimeoutError``.
        """
        self._validate_path()
        self.path.parent.mkdir(parents=True, exist_ok=True)
        deadline = time.monotonic() + timeout

        while True:
            self._break_stale_lock()
            if self._try_acquire_nb():
                return self
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                if self._break_stale_lock() and self._try_acquire_nb():
                    return self
                raise TimeoutError(
                    f"Lock {self.path} not acquired within {timeout}s"
                )
            time.sleep(min(0.5, remaining))

    # ── context manager (blocking, used by append_jsonl etc.) ──

    def __enter__(self) -> "FileLock":
        self._validate_path()
        self.path.parent.mkdir(parents=True, exist_ok=True)

        if fcntl is not None:
            # PID-based stale check, then mtime fallback, then blocking flock.
            self._break_stale_lock()
            self._clean_stale_mtime()
            self.fd = open(self.path, "a+", encoding="utf-8")
            fcntl.flock(self.fd.fileno(), fcntl.LOCK_EX)
            self._owns_lock = True
            self._write_lock_info()
        else:
            # Windows / non-fcntl: retry with stale detection up to self.timeout.
            deadline = time.monotonic() + self.timeout
            while True:
                self._break_stale_lock()
                self._clean_stale_mtime()
                if self._try_acquire_rename():
                    return self
                if time.monotonic() >= deadline:
                    raise TimeoutError(
                        f"Lock {self.path} not acquired within {self.timeout}s"
                    )
                time.sleep(0.05)

        return self

    def __exit__(self, exc_type: Any, exc: Any, tb: Any) -> None:
        """Release lock, close fd; safe to call even after prior errors."""
        try:
            if self._owns_lock and fcntl is not None and self.fd is not None:
                fcntl.flock(self.fd.fileno(), fcntl.LOCK_UN)
        except OSError:
            pass
        finally:
            if self.fd is not None:
                try:
                    self.fd.close()
                except OSError:
                    pass
                self.fd = None
            # Windows / non-fcntl: remove lock file to release.
            if self._owns_lock and fcntl is None:
                try:
                    self.path.unlink()
                except FileNotFoundError:
                    pass
            self._owns_lock = False


def lock_path_for(target: Path) -> Path:
    """Return a collision-free lock path for *target*.

    Uses sha256 of the absolute path (first 16 hex chars) so that files
    with the same name in different directories get different locks.
    """
    abs_str = str(target.resolve())
    h = hashlib.sha256(abs_str.encode("utf-8")).hexdigest()[:16]
    return data_dir() / "locks" / f"{h}.lock"


def clean_all_stale_locks() -> None:
    """Remove all stale lock files from the locks directory."""
    locks_dir = data_dir() / "locks"
    if not locks_dir.exists():
        return
    now = time.time()
    for lf in locks_dir.glob("*.lock"):
        try:
            if now - lf.stat().st_mtime > FileLock.STALE_SECONDS:
                lf.unlink(missing_ok=True)
        except OSError:
            pass


def append_jsonl(path: Path, record: Dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with FileLock(lock_path_for(path)):
        with open(path, "a", encoding="utf-8") as fh:
            fh.write(json_line(record) + "\n")


def sha256_file(path: Path) -> Optional[str]:
    try:
        h = hashlib.sha256()
        with open(path, "rb") as fh:
            for chunk in iter(lambda: fh.read(1024 * 1024), b""):
                h.update(chunk)
        return h.hexdigest()
    except (FileNotFoundError, IsADirectoryError, PermissionError, OSError):
        return None


def short(s: Any, n: int = 160) -> str:
    text = str(s or "")
    text = re.sub(r"\s+", " ", text).strip()
    if len(text) <= n:
        return text
    return text[: n - 1] + "…"


def new_id(prefix: str) -> str:
    return f"{prefix}_{uuid.uuid4().hex[:12]}"


def infer_runtime(event: Dict[str, Any]) -> str:
    env_runtime = env_first("AIDS_RUNTIME", "AID_RUNTIME", "SELFTOOLS_RUNTIME", "ZHUYI_RUNTIME")
    if env_runtime:
        return env_runtime
    transcript = str(event.get("transcript_path") or "")
    if ".codex" in transcript:
        return "codex"
    if ".claude" in transcript:
        return "claude"
    # Claude hooks expose CLAUDE_ENV_FILE on SessionStart/Setup/CwdChanged/FileChanged.
    if os.environ.get("CLAUDE_ENV_FILE"):
        return "claude"
    return "unknown"


def infer_actor_type(runtime: str) -> str:
    actor_type = env_first("AIDS_ACTOR_TYPE", "AID_ACTOR_TYPE", "SELFTOOLS_ACTOR_TYPE", "ZHUYI_ACTOR_TYPE")
    if actor_type:
        return actor_type
    if runtime in {"claude", "codex"}:
        return "agent"
    if runtime == "bash":
        return "human" if env_first("AIDS_SESSION_ID", "AID_SESSION_ID", "SESSION_ID", "SELFTOOLS_SESSION_ID", "ZHUYI_SESSION_ID") else "bash"
    return "unknown"


def session_id_from(event: Dict[str, Any]) -> str:
    return (
        env_first("AIDS_SESSION_ID", "AID_SESSION_ID", "SESSION_ID", "SELFTOOLS_SESSION_ID", "ZHUYI_SESSION_ID", "AHA_SESSION_ID")
        or str(event.get("session_id") or "")
        or f"local-{socket.gethostname()}-{os.getpid()}"
    )


def session_path(session_id: str) -> Path:
    safe = re.sub(r"[^A-Za-z0-9_.-]", "_", session_id)
    return data_dir() / "sessions" / f"{safe}.json"


def load_session(session_id: str) -> Dict[str, Any]:
    return read_json(session_path(session_id), {}) or {}


def register_session(event: Dict[str, Any], *, source: str = "hook") -> Dict[str, Any]:
    ensure_layout()
    sid = session_id_from(event)
    path = session_path(sid)
    old = read_json(path, {}) or {}
    ts = now_ms()
    runtime = infer_runtime(event)
    actor_type = infer_actor_type(runtime)
    cwd = str(event.get("cwd") or os.getcwd())
    record = dict(old)
    record.update(
        {
            "session_id": sid,
            "runtime": runtime if runtime != "unknown" else old.get("runtime", runtime),
            "model": event.get("model") or old.get("model") or env_first("AIDS_MODEL", "AID_MODEL", "SELFTOOLS_MODEL", "ZHUYI_MODEL"),
            "display_name": os.environ.get("AIDS_DISPLAY_NAME") or os.environ.get("AHA_SESSION_NAME") or os.environ.get("AID_DISPLAY_NAME") or os.environ.get("SELFTOOLS_DISPLAY_NAME") or os.environ.get("ZHUYI_DISPLAY_NAME") or (old.get("display_name") if old.get("display_name") not in (None, "", "unknown", "unspecified") else None) or sid,
            "role": os.environ.get("AIDS_ROLE") or os.environ.get("AID_ROLE") or os.environ.get("AHA_AGENT_ROLE") or os.environ.get("ROLE") or os.environ.get("SELFTOOLS_ROLE") or os.environ.get("ZHUYI_ROLE") or os.environ.get("AHA_ROLE") or (old.get("role") if old.get("role") not in (None, "", "unknown", "unspecified") else None) or "unknown",
            "actor_type": actor_type,
            "team_id": env_first("AIDS_TEAM_ID", "AID_TEAM_ID", "TEAM_ID", "SELFTOOLS_TEAM_ID", "ZHUYI_TEAM_ID", "AHA_TEAM_ID") or old.get("team_id"),
            "task_id": env_first("AIDS_TASK_ID", "AID_TASK_ID", "TASK_ID", "SELFTOOLS_TASK_ID", "ZHUYI_TASK_ID", "AHA_TASK_ID") or old.get("task_id"),
            "goal": os.environ.get("AIDS_INTENT") or os.environ.get("AID_INTENT") or os.environ.get("AHA_INTENT") or os.environ.get("AHA_AGENT_SCOPE_SUMMARY") or os.environ.get("INTENT") or os.environ.get("SELFTOOLS_INTENT") or os.environ.get("ZHUYI_INTENT") or (old.get("goal") if old.get("goal") not in (None, "", "unspecified") else None) or "",
            "project_path": cwd,
            "transcript_path": event.get("transcript_path") or old.get("transcript_path"),
            "permission_mode": event.get("permission_mode") or old.get("permission_mode"),
            "host": socket.gethostname(),
            "pid": os.getpid(),
            "status": "active",
            "source": source,
            "last_seen_at": ts,
            "last_seen_iso": iso_now(),
        }
    )
    record.setdefault("started_at", ts)
    record.setdefault("started_iso", iso_now())
    write_json_atomic(path, record)
    return record


def normalize_resource(raw: str, cwd: Optional[str] = None) -> str:
    if not raw:
        return "unknown"
    raw = str(raw)
    if raw.startswith("bash:") or raw.startswith("mcp:"):
        return raw
    # Keep URI-like targets stable.
    if re.match(r"^[a-zA-Z][a-zA-Z0-9+.-]*://", raw):
        return raw
    base = Path(cwd or os.getcwd()).expanduser()
    p = Path(raw).expanduser()
    if not p.is_absolute():
        p = base / p
    try:
        resolved = p.resolve(strict=False)
    except Exception:
        resolved = p.absolute()
    return str(resolved)


def index_key(resource: str) -> str:
    return base64.urlsafe_b64encode(resource.encode("utf-8")).decode("ascii").rstrip("=")


def index_path(resource: str) -> Path:
    return data_dir() / "index" / f"{index_key(resource)}.json"


def load_index(resource: str) -> Dict[str, Any]:
    return read_json(index_path(resource), {}) or {}


def update_index(resource: str, trace: Dict[str, Any], session: Dict[str, Any]) -> None:
    path = index_path(resource)
    lock_path = lock_path_for(path)
    with FileLock(lock_path):
        idx = read_json(path, {}) or {}
        trace_ids = list(idx.get("trace_ids") or [])
        trace_ids.append(trace["trace_id"])
        # Keep a bounded index list for fast lookup while JSONL remains canonical.
        trace_ids = trace_ids[-500:]
        idx.update(
            {
                "resource_path": resource,
                "trace_ids": trace_ids,
                "last_op": trace.get("operation"),
                "last_actor": trace.get("session_id"),
                "last_actor_role": session.get("role"),
                "last_actor_type": trace.get("actor_type") or session.get("actor_type"),
                "last_runtime": trace.get("runtime") or session.get("runtime"),
                "last_intent": trace.get("intent"),
                "last_seen_at": trace.get("timestamp"),
                "timeline_path": str(data_dir() / "timeline" / f"{today()}.jsonl"),
                "total_ops": int(idx.get("total_ops") or 0) + 1,
            }
        )
        if trace.get("operation") in {"create", "modify", "delete"}:
            idx.update(
                {
                    "last_writer": trace.get("session_id"),
                    "last_writer_role": session.get("role"),
                    "last_write_intent": trace.get("intent"),
                    "last_write_at": trace.get("timestamp"),
                }
            )
        write_json_atomic(path, idx)


def traces_file_for_today() -> Path:
    return data_dir() / "traces" / f"{today()}.jsonl"


def timeline_file_for_today() -> Path:
    return data_dir() / "timeline" / f"{today()}.jsonl"


def timeline_event_from_trace(trace: Dict[str, Any], event: Dict[str, Any], session: Dict[str, Any]) -> Dict[str, Any]:
    return {
        "schema_version": "aids.timeline.v1",
        "event_id": new_id("ev"),
        "trace_id": trace.get("trace_id"),
        "parent_trace_id": trace.get("parent_trace_id"),
        "timestamp": trace.get("timestamp"),
        "timestamp_iso": trace.get("timestamp_iso"),
        "actor_type": trace.get("actor_type") or session.get("actor_type") or "unknown",
        "runtime": trace.get("runtime") or session.get("runtime") or "unknown",
        "session_id": trace.get("session_id") or "unknown",
        "role": session.get("role"),
        "tool": trace.get("tool") or "unknown",
        "resource": trace.get("resource_path") or "unknown",
        "intent": trace.get("intent") or "unspecified",
        "operation": trace.get("operation"),
        "result": event.get("tool_response"),
        "native": {"hook_event": event.get("hook_event_name"), "tool_use_id": event.get("tool_use_id")},
        "metadata": {"trace": trace},
    }


def trace_paths() -> Iterable[Path]:
    traces_dir = data_dir() / "traces"
    if not traces_dir.exists():
        return []
    return sorted(traces_dir.glob("*.jsonl"))


def read_trace(trace_id: str) -> Optional[Dict[str, Any]]:
    for path in trace_paths():
        try:
            with open(path, "r", encoding="utf-8") as fh:
                for line in fh:
                    if trace_id in line:
                        try:
                            obj = json.loads(line)
                        except json.JSONDecodeError:
                            continue
                        if obj.get("trace_id") == trace_id:
                            return obj
        except FileNotFoundError:
            continue
    return None


def recent_traces(resource: str, limit: int = RECENT_LIMIT) -> List[Dict[str, Any]]:
    idx = load_index(resource)
    ids = list(idx.get("trace_ids") or [])[-limit:]
    out: List[Dict[str, Any]] = []
    for tid in ids:
        trace = read_trace(tid)
        if trace:
            sess = load_session(str(trace.get("session_id") or ""))
            trace = dict(trace)
            trace["session"] = sess
            out.append(trace)
    return out


def detect_resources(tool_name: str, tool_input: Any, cwd: str) -> List[str]:
    resources: List[str] = []
    if not isinstance(tool_input, dict):
        return resources
    # Claude file tools.
    for key in ("file_path", "filePath", "path"):
        val = tool_input.get(key)
        if isinstance(val, str) and val and tool_name not in {"Bash"}:
            resources.append(normalize_resource(val, cwd))
    # Codex apply_patch exposes patch text under command.
    if tool_name == "apply_patch" or ("*** Begin Patch" in str(tool_input.get("command") or "")):
        resources.extend(parse_apply_patch_resources(str(tool_input.get("command") or ""), cwd))
    if tool_name == "Bash":
        cmd = short(tool_input.get("command") or "", 240)
        resources.append(f"bash:{cmd}")
    if tool_name.startswith("mcp__"):
        resources.append(f"mcp:{tool_name}")
    # De-dupe while preserving order.
    seen = set()
    clean = []
    for res in resources:
        if res and res not in seen:
            seen.add(res)
            clean.append(res)
    return clean


def parse_apply_patch_resources(command: str, cwd: str) -> List[str]:
    resources: List[str] = []
    patterns = [
        r"^\*\*\* (?:Update|Add|Delete) File: (.+)$",
        r"^---\s+(?:a/)?(.+)$",
        r"^\+\+\+\s+(?:b/)?(.+)$",
    ]
    for line in command.splitlines():
        for pat in patterns:
            m = re.match(pat, line.strip())
            if m:
                name = m.group(1).strip()
                if name != "/dev/null":
                    resources.append(normalize_resource(name, cwd))
                break
    seen = set()
    out = []
    for res in resources:
        if res not in seen:
            seen.add(res)
            out.append(res)
    return out


def operation_for(tool_name: str, resource: str, pre_hash: Optional[str], post_hash: Optional[str]) -> str:
    if tool_name == "Read":
        return "read"
    if tool_name == "Bash" or resource.startswith("bash:"):
        return "execute"
    if post_hash is None and pre_hash is not None:
        return "delete"
    if pre_hash is None and post_hash is not None:
        return "create"
    if pre_hash != post_hash:
        return "modify"
    return "touch"


def pending_path(tool_use_id: str) -> Path:
    safe = re.sub(r"[^A-Za-z0-9_.-]", "_", tool_use_id or "unknown")
    return data_dir() / "pending" / f"{safe}.json"


def save_pending(event: Dict[str, Any], session: Dict[str, Any], resources: List[str]) -> None:
    tool_use_id = str(event.get("tool_use_id") or event.get("turn_id") or new_id("pending"))
    cwd = str(event.get("cwd") or os.getcwd())
    pending_resources = []
    for res in resources:
        pre_hash = None if res.startswith(("bash:", "mcp:")) else sha256_file(Path(res))
        pending_resources.append({"resource_path": res, "pre_hash": pre_hash})
    record = {
        "tool_use_id": tool_use_id,
        "session_id": session.get("session_id"),
        "tool_name": event.get("tool_name"),
        "tool_input": event.get("tool_input"),
        "resources": pending_resources,
        "cwd": cwd,
        "timestamp": now_ms(),
    }
    write_json_atomic(pending_path(tool_use_id), record)


def load_pending(event: Dict[str, Any]) -> Dict[str, Any]:
    tool_use_id = str(event.get("tool_use_id") or event.get("turn_id") or "")
    if tool_use_id:
        return read_json(pending_path(tool_use_id), {}) or {}
    return {}


def remove_pending(event: Dict[str, Any]) -> None:
    tool_use_id = str(event.get("tool_use_id") or event.get("turn_id") or "")
    if not tool_use_id:
        return
    try:
        pending_path(tool_use_id).unlink()
    except FileNotFoundError:
        pass




def gitnexus_enabled() -> bool:
    return env_first("AIDS_GITNEXUS", "AID_GITNEXUS", "SELFTOOLS_GITNEXUS") != "0"


def run_gitnexus(args: List[str], cwd: str, timeout: int = 8) -> Optional[subprocess.CompletedProcess]:
    if not gitnexus_enabled():
        return None
    gn = shutil.which("gitnexus")
    if not gn:
        return None
    try:
        return subprocess.run(
            [gn, *args], cwd=cwd, text=True,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            timeout=timeout, check=False,
        )
    except Exception:
        return None


def gitnexus_file_context(file_path: str, cwd: Optional[str] = None) -> Optional[Dict[str, Any]]:
    if not gitnexus_enabled():
        return None
    work_dir = cwd or os.getcwd()
    try:
        rel = os.path.relpath(file_path, work_dir)
    except Exception:
        rel = file_path
    ctx: Dict[str, Any] = {"enabled": True, "path": rel, "available": False, "importance": "unknown", "summary": ""}
    proc = run_gitnexus(["query", rel], work_dir, timeout=8)
    if not proc:
        ctx["summary"] = "GitNexus unavailable or repo not indexed."
        return ctx
    output = (proc.stdout or proc.stderr or "").strip()
    ctx["available"] = True
    ctx["summary"] = output[:1200]
    lowered = output.lower()
    hits = sum(tok in lowered for tok in ["critical", "route", "api", "handler", "caller", "impact", "process"])
    ctx["importance"] = "high" if hits >= 3 else ("medium" if hits >= 1 else "low")
    return ctx

def format_recent_context(resources: List[str], session: Dict[str, Any], limit: int = RECENT_LIMIT) -> str:
    lines: List[str] = []
    for res in resources:
        traces = recent_traces(res, limit=limit)
        display = res
        try:
            cwd = session.get("project_path") or os.getcwd()
            display = os.path.relpath(res, cwd) if not res.startswith(("bash:", "mcp:")) else res
        except Exception:
            pass
        if not traces:
            lines.append(f"- {display}: no prior {ZH_NAME} trace found.")
            continue
        lines.append(f"- {display}: recent trace chain")
        for tr in traces[-limit:]:
            sess = tr.get("session") or {}
            actor = sess.get("display_name") or tr.get("session_id") or "unknown"
            role = sess.get("role") or "unknown"
            intent = tr.get("intent") or sess.get("goal") or "unspecified"
            op = tr.get("operation") or tr.get("tool")
            ts = tr.get("timestamp")
            ago = human_ago(ts) if isinstance(ts, int) else "unknown time"
            lines.append(f"  • {op} by {actor} ({role}) {ago}; intent: {short(intent, 120)}; trace: {tr.get('trace_id')}")
    return "\n".join(lines)


def human_ago(timestamp_ms: int) -> str:
    delta = max(0, now_ms() - timestamp_ms) / 1000.0
    if delta < 60:
        return f"{int(delta)}s ago"
    if delta < 3600:
        return f"{int(delta // 60)}m ago"
    if delta < 86400:
        return f"{int(delta // 3600)}h ago"
    return f"{int(delta // 86400)}d ago"


def hook_output(event_name: str, message: str, *, post: bool = False) -> None:
    # Emit both Claude-friendly hookSpecificOutput and Codex-friendly systemMessage.
    out: Dict[str, Any] = {"systemMessage": message}
    hook_specific: Dict[str, Any] = {"hookEventName": event_name}
    if event_name in {"SessionStart", "PreToolUse", "PostToolUse"}:
        hook_specific["additionalContext"] = message
    if post:
        # Claude PostToolUse supports top-level additionalContext too.
        out["additionalContext"] = message
    out["hookSpecificOutput"] = hook_specific
    print(json_line(out))


def cmd_hook_session_start(_: argparse.Namespace) -> int:
    event = read_stdin_json()
    session = register_session(event, source="session-start")
    env_lines = [
        f"export AIDS_SESSION_ID={shlex.quote(str(session['session_id']))}",
        f"export AID_SESSION_ID={shlex.quote(str(session['session_id']))}",
        f"export SESSION_ID={shlex.quote(str(session['session_id']))}",
        f"export ZHUYI_SESSION_ID={shlex.quote(str(session['session_id']))}",
        f"export SELFTOOLS_SESSION_ID={shlex.quote(str(session['session_id']))}",
        f"export AIDS_RUNTIME={shlex.quote(str(session.get('runtime') or 'unknown'))}",
        f"export AIDS_ACTOR_TYPE={shlex.quote(str(session.get('actor_type') or 'unknown'))}",
        f"export AIDS_DATA_DIR={shlex.quote(str(data_dir()))}",
        f"export AIDS_HOME={shlex.quote(str(data_dir()))}",
        f"export AID_DATA_DIR={shlex.quote(str(data_dir()))}",
        f"export AID_HOME={shlex.quote(str(data_dir()))}",
        f"export ZHUYI_DATA_DIR={shlex.quote(str(data_dir()))}",
        f"export SELFTOOLS_DATA_DIR={shlex.quote(str(data_dir()))}",
    ]
    env_file = os.environ.get("CLAUDE_ENV_FILE")
    if env_file:
        try:
            with open(env_file, "a", encoding="utf-8") as fh:
                fh.write("\n# AIDS (Agent-ID System) session identity; legacy aliases included\n")
                fh.write("\n".join(env_lines) + "\n")
        except OSError as exc:
            append_log({"level": "warn", "event": "env_file_write_failed", "error": str(exc)})

    # ── Self-reference: write identity files ──
    write_identity_files(session)

    # ── Enriched SessionStart message with identity template ──
    role = session.get('role') or 'unknown'
    runtime = session.get('runtime') or 'unknown'
    display = session.get('display_name') or session['session_id']
    goal = short(session.get('goal'), 120) or '(none)'
    message = (
        f"{ZH_NAME} session registered.\n"
        f"You are {display} (role={role}, runtime={runtime}).\n"
        f"session_id={session['session_id']}\n"
        f"goal={goal}\n"
        f"Use `aids who-touched <path>` or `aids op-chain <path>` before risky edits."
    )
    hook_output("SessionStart", message)
    return 0


def cmd_hook_pre_tool_use(_: argparse.Namespace) -> int:
    event = read_stdin_json()
    session = register_session(event, source="pre-tool-use")
    tool_name = str(event.get("tool_name") or "")
    cwd = str(event.get("cwd") or os.getcwd())
    resources = detect_resources(tool_name, event.get("tool_input"), cwd)
    if resources:
        save_pending(event, session, resources)
    if tool_name in WRITE_TOOL_NAMES and resources:
        context = format_recent_context(resources, session)
        # GitNexus code-graph awareness
        gn_lines = []
        for res in resources:
            if not res.startswith(("bash:", "mcp:")):
                gn = gitnexus_file_context(res, cwd)
                if gn and gn.get("available"):
                    gn_lines.append(f"- GitNexus importance: {gn['importance']}")
                    gn_lines.append(f"- GitNexus context: {short(gn['summary'], 300)}")
        if gn_lines:
            context += "\n" + "\n".join(gn_lines)
        # Self-reference: show who is about to write
        who_am_i = f"{session.get('display_name') or session.get('session_id', '?')} ({session.get('role', '?')})"
        message = f"写前必读 / AIDS awareness for {tool_name}:\nYou are {who_am_i} about to write.\n{context}"
        hook_output("PreToolUse", message)
    return 0


def cmd_hook_post_tool_use(_: argparse.Namespace) -> int:
    event = read_stdin_json()
    session = register_session(event, source="post-tool-use")
    tool_name = str(event.get("tool_name") or "")
    cwd = str(event.get("cwd") or os.getcwd())
    pending = load_pending(event)
    resources_from_pending = pending.get("resources") or []
    if resources_from_pending:
        resources = [str(r.get("resource_path")) for r in resources_from_pending if r.get("resource_path")]
        pre_by_resource = {str(r.get("resource_path")): r.get("pre_hash") for r in resources_from_pending}
    else:
        resources = detect_resources(tool_name, event.get("tool_input"), cwd)
        pre_by_resource = {res: (None if res.startswith(("bash:", "mcp:")) else sha256_file(Path(res))) for res in resources}
    trace_ids: List[str] = []
    intent = env_first("AIDS_INTENT", "AID_INTENT", "INTENT", "SELFTOOLS_INTENT", "ZHUYI_INTENT") or session.get("goal") or tool_intent(event)
    for res in resources:
        pre_hash = pre_by_resource.get(res)
        post_hash = None if res.startswith(("bash:", "mcp:")) else sha256_file(Path(res))
        if tool_name == "Read":
            post_hash = None
        trace = {
            "trace_id": new_id("tr"),
            "session_id": session.get("session_id"),
            "tool": tool_name or "unknown",
            "resource_path": res,
            "operation": operation_for(tool_name, res, pre_hash, post_hash),
            "intent": intent,
            "pre_hash": pre_hash,
            "post_hash": post_hash,
            "duration_ms": event.get("duration_ms"),
            "timestamp": now_ms(),
            "timestamp_iso": iso_now(),
            "runtime": session.get("runtime") or infer_runtime(event),
            "actor_type": session.get("actor_type") or infer_actor_type(str(session.get("runtime") or "unknown")),
            "role": session.get("role"),
            "team_id": session.get("team_id"),
            "display_name": session.get("display_name"),
            "cwd": cwd,
            "tool_use_id": event.get("tool_use_id"),
            "metadata": {
                "runtime": session.get("runtime"),
                "permission_mode": event.get("permission_mode"),
                "tool_response_preview": short(event.get("tool_response"), 500),
            },
        }
        trace["timeline_path"] = str(timeline_file_for_today())
        append_jsonl(traces_file_for_today(), trace)
        append_jsonl(timeline_file_for_today(), timeline_event_from_trace(trace, event, session))
        update_index(res, trace, session)
        trace_ids.append(trace["trace_id"])
    remove_pending(event)
    if trace_ids:
        hook_output("PostToolUse", f"{ZH_NAME} recorded {len(trace_ids)} trace(s): {', '.join(trace_ids)}", post=True)
    return 0


def tool_intent(event: Dict[str, Any]) -> str:
    ti = event.get("tool_input")
    if isinstance(ti, dict):
        for key in ("description", "prompt", "command"):
            if ti.get(key):
                return short(ti.get(key), 220)
    return "unspecified"


def print_traces_for_resource(resource_arg: str, limit: int, *, as_json: bool = False) -> int:
    res = normalize_resource(resource_arg)
    traces = recent_traces(res, limit=limit)
    if as_json:
        print(json_dump({"resource_path": res, "traces": traces}))
        return 0
    if not traces:
        print(f"No {ZH_NAME} traces for {res}")
        return 1
    print(f"{ZH_NAME} traces for {res}:")
    for tr in traces:
        sess = tr.get("session") or {}
        actor = sess.get("display_name") or tr.get("session_id")
        print(
            f"- {tr.get('trace_id')} {tr.get('operation')} {tr.get('tool')} by {actor} "
            f"({sess.get('role', 'unknown')}) {human_ago(int(tr.get('timestamp') or now_ms()))}; intent: {short(tr.get('intent'), 140)}"
        )
    return 0


def cmd_who_touched(args: argparse.Namespace) -> int:
    return print_traces_for_resource(args.path, args.limit, as_json=args.json)


def cmd_op_chain(args: argparse.Namespace) -> int:
    return print_traces_for_resource(args.path, args.limit, as_json=args.json)


def cmd_session_info(args: argparse.Namespace) -> int:
    record = load_session(args.session_id)
    if not record:
        print(f"No session found for {args.session_id}", file=sys.stderr)
        return 1
    if args.json:
        print(json_dump(record))
    else:
        print(f"session_id: {record.get('session_id')}")
        print(f"runtime:    {record.get('runtime')}")
        print(f"role:       {record.get('role')}")
        print(f"display:    {record.get('display_name')}")
        print(f"goal:       {record.get('goal')}")
        print(f"task_id:    {record.get('task_id')}")
        print(f"last_seen:  {record.get('last_seen_iso')}")
    return 0


def cmd_retire_session(args: argparse.Namespace) -> int:
    ensure_layout()
    sid = args.session_id
    record = load_session(sid)
    if not record:
        print(f"No session found for {sid}", file=sys.stderr)
        return 1
    record["status"] = "retired"
    record["last_seen_at"] = now_ms()
    record["last_seen_iso"] = iso_now()
    if args.reason:
        record["retire_reason"] = args.reason
    write_json_atomic(session_path(sid), record)
    if args.json:
        print(json_dump(record))
    else:
        print(f"Session {sid} retired.")
    return 0


def cmd_list_sessions(args: argparse.Namespace) -> int:
    ensure_layout()
    sessions_dir = data_dir() / "sessions"
    if not sessions_dir.exists():
        print("No sessions found." if not args.json else '{"sessions": []}')
        return 0
    records = []
    for f in sorted(sessions_dir.glob("*.json")):
        rec = read_json(f, {})
        if rec:
            records.append(rec)
    if args.status:
        records = [r for r in records if r.get("status") == args.status]
    if args.role:
        records = [r for r in records if r.get("role") == args.role]
    if args.runtime:
        records = [r for r in records if r.get("runtime") == args.runtime]
    if args.json:
        print(json_dump({"sessions": records}))
    else:
        if not records:
            print("No matching sessions.")
            return 0
        for r in records:
            sid = r.get("session_id", "?")
            role = r.get("role", "?")
            status = r.get("status", "?")
            name = r.get("display_name", "")
            goal = short(r.get("goal"), 60)
            print(f"  {sid}  {role:15s}  {status:8s}  {name:30s}  {goal}")
    return 0


def cmd_heartbeat(args: argparse.Namespace) -> int:
    ensure_layout()
    sid = args.session_id
    record = load_session(sid)
    if not record:
        print(f"No session found for {sid}", file=sys.stderr)
        return 1
    record["last_seen_at"] = now_ms()
    record["last_seen_iso"] = iso_now()
    write_json_atomic(session_path(sid), record)
    if args.json:
        print(json_dump(record))
    else:
        print(f"Session {sid} heartbeat at {record['last_seen_iso']}.")
    return 0


def cmd_whois(args: argparse.Namespace) -> int:
    ensure_layout()
    sid = args.session_id
    record = load_session(sid)
    if not record:
        print(f"Unknown session: {sid}", file=sys.stderr)
        return 1
    if args.json:
        print(json_dump(record))
        return 0
    age_min = round((now_ms() - (record.get("started_at") or now_ms())) / 60000)
    last = record.get("last_seen_at") or record.get("started_at") or now_ms()
    ago = round((now_ms() - last) / 60000)
    print(f"Session: {record.get('session_id')}")
    print(f"  Role:         {record.get('role', '?')}")
    print(f"  Name:         {record.get('display_name', '(unnamed)')}")
    print(f"  Runtime:      {record.get('runtime', '?')}{('/' + record['model']) if record.get('model') else ''}")
    print(f"  Goal:         {record.get('goal', '(none)')}")
    print(f"  Task:         {record.get('task_id', '(none)')}")
    print(f"  Team:         {record.get('team_id', '(none)')}")
    print(f"  Project:      {record.get('project_path', '(none)')}")
    print(f"  Status:       {record.get('status', '?')}")
    print(f"  Uptime:       {age_min}m")
    print(f"  Last seen:    {ago}m ago")
    return 0


def cmd_register_session(args: argparse.Namespace) -> int:
    event = {
        "session_id": args.session_id or env_first("AIDS_SESSION_ID", "AID_SESSION_ID", "SESSION_ID", "SELFTOOLS_SESSION_ID", "ZHUYI_SESSION_ID") or new_id("sess"),
        "cwd": args.cwd or os.getcwd(),
        "model": args.model,
    }
    # Supply env-like overrides through process env to keep one code path.
    if args.runtime:
        os.environ["AIDS_RUNTIME"] = args.runtime
    if args.role:
        os.environ["AIDS_ROLE"] = args.role
    if args.goal:
        os.environ["AIDS_INTENT"] = args.goal
    if args.team_id:
        os.environ["AIDS_TEAM_ID"] = args.team_id
    if args.task_id:
        os.environ["AIDS_TASK_ID"] = args.task_id
    if args.display_name:
        os.environ["AIDS_DISPLAY_NAME"] = args.display_name
    record = register_session(event, source="cli")
    print(json_dump(record))
    return 0


def cmd_rate(args: argparse.Namespace) -> int:
    ensure_layout()
    trace = read_trace(args.trace_id)
    if trace is None:
        print(f"Trace not found: {args.trace_id}", file=sys.stderr)
        return 1
    rater = env_first("AIDS_SESSION_ID", "AID_SESSION_ID", "SESSION_ID", "SELFTOOLS_SESSION_ID", "ZHUYI_SESSION_ID") or "anonymous"
    rating = {
        "rating_id": new_id("rt"),
        "trace_id": args.trace_id,
        "rater_session_id": rater,
        "score": args.score,
        "comment": " ".join(args.comment).strip(),
        "context": env_first("AIDS_INTENT", "AID_INTENT", "INTENT", "SELFTOOLS_INTENT", "ZHUYI_INTENT"),
        "timestamp": now_ms(),
        "timestamp_iso": iso_now(),
        "runtime": env_first("AIDS_RUNTIME", "AID_RUNTIME", "SELFTOOLS_RUNTIME", "ZHUYI_RUNTIME") or "unknown",
        "rater_actor_type": env_first("AIDS_ACTOR_TYPE", "AID_ACTOR_TYPE", "SELFTOOLS_ACTOR_TYPE", "ZHUYI_ACTOR_TYPE") or "unknown",
    }
    append_jsonl(data_dir() / "ratings" / f"{today()}.jsonl", rating)
    print(json_dump(rating))
    return 0


def cmd_timeline(args: argparse.Namespace) -> int:
    ensure_layout()
    tl_file = timeline_file_for_today()
    if not tl_file.exists():
        print("No timeline events today.", file=sys.stderr)
        return 1
    events = [json.loads(l) for l in tl_file.read_text().strip().splitlines() if l.strip()]
    events = events[-args.limit:]
    if args.json:
        print(json_dump({"count": len(events), "events": events}))
        return 0
    for ev in events:
        ts = ev.get("timestamp_iso", "?")
        tool = ev.get("tool", "?")
        sid = str(ev.get("session_id", "?"))[:8]
        res = str(ev.get("resource", ev.get("resource_path", "")))[:60]
        runtime = ev.get("runtime", "?")
        actor = ev.get("actor_type", "?")
        print(f"{ts[11:19]} {actor}/{runtime} {sid} {tool} {res}")
    return 0


def _date_range(args: argparse.Namespace) -> Tuple[Optional[str], Optional[str]]:
    """Return (date_from, date_to) strings in YYYY-MM-DD, respecting --from/--to/--all."""
    if getattr(args, "all", False):
        return None, None
    date_from = getattr(args, "from_date", None)
    date_to = getattr(args, "to_date", None)
    if not date_from and not date_to:
        days = getattr(args, "days", 7)
        to = _dt.date.today()
        frm = to - _dt.timedelta(days=days - 1)
        return frm.strftime("%Y-%m-%d"), to.strftime("%Y-%m-%d")
    return date_from, date_to


def _jsonl_files_in_range(directory: Path, date_from: Optional[str], date_to: Optional[str]) -> List[Path]:
    """Return JSONL files in directory whose YYYY-MM-DD name falls within range."""
    if not directory.exists():
        return []
    out: List[Path] = []
    for f in sorted(directory.glob("*.jsonl")):
        stem = f.stem  # e.g. 2025-05-18
        if len(stem) == 10 and stem[4] == "-" and stem[7] == "-":
            if date_from and stem < date_from:
                continue
            if date_to and stem > date_to:
                continue
        out.append(f)
    return out


def _iter_jsonl_lines(files: List[Path]) -> Iterable[Dict[str, Any]]:
    for f in files:
        try:
            text = f.read_text(encoding="utf-8")
        except (FileNotFoundError, PermissionError):
            continue
        for line in text.splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                yield json.loads(line)
            except json.JSONDecodeError:
                continue


EXPORT_SCHEMA_VERSION = "aids.export.v1"
EXPORT_TYPES = ("traces", "timeline", "ratings", "sessions")
CSV_EXPORT_TYPES = {"traces", "timeline"}


def _validate_date_string(value: Optional[str], label: str) -> Optional[str]:
    if not value:
        return None
    try:
        _dt.date.fromisoformat(value)
    except ValueError as exc:
        raise ValueError(f"{label} must be YYYY-MM-DD: {value}") from exc
    return value


def _export_date_range(args: argparse.Namespace) -> Tuple[Optional[str], Optional[str]]:
    """Return export date range; default export is all-time unless --days is set."""
    if getattr(args, "all", False):
        return None, None
    date_from = _validate_date_string(getattr(args, "from_date", None), "--from")
    date_to = _validate_date_string(getattr(args, "to_date", None), "--to")
    if not date_from and not date_to and getattr(args, "days", None):
        days = max(1, int(getattr(args, "days")))
        to = _dt.date.today()
        frm = to - _dt.timedelta(days=days - 1)
        date_from, date_to = frm.isoformat(), to.isoformat()
    if date_from and date_to and date_from > date_to:
        raise ValueError(f"--from must be on or before --to: {date_from} > {date_to}")
    return date_from, date_to


def _record_date(record: Dict[str, Any]) -> Optional[str]:
    """Best-effort YYYY-MM-DD date from a session or loose record."""
    for key in ("timestamp_iso", "started_iso", "last_seen_iso"):
        value = record.get(key)
        if isinstance(value, str) and len(value) >= 10:
            try:
                return _dt.date.fromisoformat(value[:10]).isoformat()
            except ValueError:
                pass
    for key in ("timestamp", "started_at", "last_seen_at"):
        value = record.get(key)
        if isinstance(value, (int, float)):
            try:
                return _dt.datetime.fromtimestamp(value / 1000.0, tz=_dt.timezone.utc).date().isoformat()
            except (OverflowError, OSError, ValueError):
                pass
    return None


def _date_matches(record: Dict[str, Any], date_from: Optional[str], date_to: Optional[str]) -> bool:
    if not date_from and not date_to:
        return True
    rec_date = _record_date(record)
    if not rec_date:
        return False
    if date_from and rec_date < date_from:
        return False
    if date_to and rec_date > date_to:
        return False
    return True


def _export_type_names(type_name: str) -> List[str]:
    if type_name == "all":
        return list(EXPORT_TYPES)
    if type_name not in EXPORT_TYPES:
        raise ValueError(f"Unsupported export type: {type_name}")
    return [type_name]


def _normalize_export_resource(resource: Optional[str]) -> Optional[str]:
    if not resource:
        return None
    return normalize_resource(resource)


def _record_matches_filters(
    record: Dict[str, Any],
    kind: str,
    session_filter: Optional[str],
    resource_filter: Optional[str],
) -> bool:
    if session_filter:
        if kind == "ratings":
            if record.get("rater_session_id") != session_filter and record.get("session_id") != session_filter:
                return False
        elif record.get("session_id") != session_filter:
            return False
    if resource_filter:
        if kind not in {"traces", "timeline"}:
            return False
        resource_value = record.get("resource_path") or record.get("resource")
        if resource_value != resource_filter and _normalize_export_resource(str(resource_value or "")) != resource_filter:
            return False
    return True


def _load_session_export_records(
    sessions_dir: Path,
    date_from: Optional[str],
    date_to: Optional[str],
    session_filter: Optional[str],
) -> List[Dict[str, Any]]:
    if not sessions_dir.exists():
        return []
    records: List[Dict[str, Any]] = []
    for f in sorted(sessions_dir.glob("*.json")):
        rec = read_json(f, {})
        if not isinstance(rec, dict) or not rec:
            continue
        if session_filter and rec.get("session_id") != session_filter:
            continue
        if not _date_matches(rec, date_from, date_to):
            continue
        records.append(rec)
    return records


def _load_export_records(
    dd: Path,
    kind: str,
    date_from: Optional[str],
    date_to: Optional[str],
    session_filter: Optional[str],
    resource_filter: Optional[str],
) -> List[Dict[str, Any]]:
    if kind == "sessions":
        if resource_filter:
            return []
        return _load_session_export_records(dd / "sessions", date_from, date_to, session_filter)

    directory = dd / kind
    files = _jsonl_files_in_range(directory, date_from, date_to)
    return [
        rec
        for rec in _iter_jsonl_lines(files)
        if _record_matches_filters(rec, kind, session_filter, resource_filter)
    ]


def _export_metadata(
    dd: Path,
    fmt: str,
    type_name: str,
    type_names: List[str],
    date_from: Optional[str],
    date_to: Optional[str],
    session_filter: Optional[str],
    resource_filter: Optional[str],
    counts: Dict[str, int],
) -> Dict[str, Any]:
    total = sum(counts.values())
    return {
        "schema_version": EXPORT_SCHEMA_VERSION,
        "exported_at": iso_now(),
        "data_dir": str(dd),
        "format": fmt,
        "type": type_name,
        "types": type_names,
        "date_range": {"from": date_from, "to": date_to},
        "filters": {"session": session_filter, "resource": resource_filter},
        "record_count": total,
        "record_counts": counts,
    }


def _open_export_output(output_path: Optional[str]) -> Tuple[Any, bool]:
    if not output_path or output_path == "-":
        return sys.stdout, False
    path = Path(output_path).expanduser()
    path.parent.mkdir(parents=True, exist_ok=True)
    return open(path, "w", encoding="utf-8", newline=""), True


def _csv_value(value: Any) -> Any:
    if value is None:
        return ""
    if isinstance(value, (dict, list)):
        return json_line(value)
    return value


def _csv_columns(kind: str, records: List[Dict[str, Any]]) -> List[str]:
    preferred = {
        "traces": [
            "trace_id", "timestamp_iso", "timestamp", "session_id", "display_name",
            "role", "runtime", "actor_type", "tool", "operation", "resource_path",
            "intent", "pre_hash", "post_hash", "duration_ms", "team_id", "cwd",
            "tool_use_id", "timeline_path",
        ],
        "timeline": [
            "event_id", "trace_id", "parent_trace_id", "timestamp_iso", "timestamp",
            "session_id", "role", "runtime", "actor_type", "tool", "operation",
            "resource", "intent",
        ],
    }[kind]
    seen = set(preferred)
    extras = sorted(
        key
        for rec in records
        for key in rec.keys()
        if key not in seen and not isinstance(rec.get(key), (dict, list))
    )
    return preferred + extras


def cmd_stats(args: argparse.Namespace) -> int:
    ensure_layout()
    dd = data_dir()
    date_from, date_to = _date_range(args)

    # ── Sessions ──
    sessions_dir = dd / "sessions"
    sessions: List[Dict[str, Any]] = []
    if sessions_dir.exists():
        for f in sessions_dir.glob("*.json"):
            rec = read_json(f, {})
            if rec:
                sessions.append(rec)

    # Filter sessions by date if needed
    if date_from or date_to:
        filtered = []
        for s in sessions:
            started = s.get("started_iso") or ""
            started_date = started[:10]  # YYYY-MM-DD
            if date_from and started_date and started_date < date_from:
                continue
            if date_to and started_date and started_date > date_to:
                continue
            filtered.append(s)
        sessions = filtered

    sess_total = len(sessions)
    sess_by_status: Dict[str, int] = {}
    sess_by_runtime: Dict[str, int] = {}
    sess_by_role: Dict[str, int] = {}
    for s in sessions:
        st = s.get("status") or "unknown"
        rt = s.get("runtime") or "unknown"
        rl = s.get("role") or "unknown"
        sess_by_status[st] = sess_by_status.get(st, 0) + 1
        sess_by_runtime[rt] = sess_by_runtime.get(rt, 0) + 1
        sess_by_role[rl] = sess_by_role.get(rl, 0) + 1

    # ── Traces ──
    trace_files = _jsonl_files_in_range(dd / "traces", date_from, date_to)
    trace_count = 0
    op_counts: Dict[str, int] = {}
    trace_by_session: Dict[str, int] = {}
    trace_by_runtime: Dict[str, int] = {}
    resource_counts: Dict[str, int] = {}
    for tr in _iter_jsonl_lines(trace_files):
        trace_count += 1
        op = tr.get("operation") or "unknown"
        op_counts[op] = op_counts.get(op, 0) + 1
        sid = tr.get("session_id") or "unknown"
        trace_by_session[sid] = trace_by_session.get(sid, 0) + 1
        rt = tr.get("runtime") or "unknown"
        trace_by_runtime[rt] = trace_by_runtime.get(rt, 0) + 1
        res = tr.get("resource_path") or "unknown"
        resource_counts[res] = resource_counts.get(res, 0) + 1

    # ── Timeline ──
    tl_files = _jsonl_files_in_range(dd / "timeline", date_from, date_to)
    timeline_count = sum(1 for _ in _iter_jsonl_lines(tl_files))

    # ── Ratings ──
    rating_files = _jsonl_files_in_range(dd / "ratings", date_from, date_to)
    rating_count = 0
    rating_dist: Dict[str, int] = {}
    for r in _iter_jsonl_lines(rating_files):
        rating_count += 1
        sc = r.get("score") or "unknown"
        rating_dist[sc] = rating_dist.get(sc, 0) + 1

    # ── Resources ──
    unique_resources = len(resource_counts)
    top_resources = sorted(resource_counts.items(), key=lambda x: -x[1])[:5]

    # ── Top 5 most active sessions ──
    top_sessions = sorted(trace_by_session.items(), key=lambda x: -x[1])[:5]
    # Enrich with session metadata
    top_sessions_enriched = []
    for sid, count in top_sessions:
        meta = load_session(sid)
        top_sessions_enriched.append({
            "session_id": sid,
            "ops": count,
            "role": (meta.get("role") or "unknown"),
            "runtime": (meta.get("runtime") or "unknown"),
            "display_name": (meta.get("display_name") or sid),
        })

    # ── Output ──
    if getattr(args, "json", False):
        result = {
            "date_range": {"from": date_from, "to": date_to},
            "sessions": {
                "total": sess_total,
                "by_status": sess_by_status,
                "by_runtime": sess_by_runtime,
                "by_role": sess_by_role,
            },
            "traces": {
                "total": trace_count,
                "by_operation": op_counts,
                "by_runtime": trace_by_runtime,
            },
            "resources": {
                "unique": unique_resources,
                "top": [{"path": p, "ops": c} for p, c in top_resources],
            },
            "timeline_events": timeline_count,
            "ratings": {
                "total": rating_count,
                "distribution": rating_dist,
            },
            "top_sessions": top_sessions_enriched,
        }
        print(json_dump(result))
        return 0

    # Human-readable
    range_label = f"{date_from or 'beginning'} → {date_to or 'now'}"
    print(f"AIDS Statistics ({range_label})")
    print()

    # Sessions
    status_parts = ", ".join(f"{k}: {v}" for k, v in sorted(sess_by_status.items()))
    runtime_parts = ", ".join(f"{k}: {v}" for k, v in sorted(sess_by_runtime.items()))
    print(f"Sessions: {sess_total} total ({status_parts})")
    print(f"  By runtime: {runtime_parts}")

    # Traces
    op_parts = ", ".join(f"{k}: {v}" for k, v in sorted(op_counts.items()))
    print(f"Traces:   {trace_count} total ({op_parts})")
    tr_runtime_parts = ", ".join(f"{k}: {v}" for k, v in sorted(trace_by_runtime.items()))
    if tr_runtime_parts:
        print(f"  By runtime: {tr_runtime_parts}")

    # Resources
    print(f"Resources touched: {unique_resources} unique")
    if top_resources:
        print("  Top resources:")
        for p, c in top_resources:
            display = p
            try:
                display = os.path.relpath(p)
            except Exception:
                pass
            display = short(display, 60)
            print(f"    {display} ({c} ops)")

    # Ratings
    rating_parts = ", ".join(f"{k}: {v}" for k, v in sorted(rating_dist.items()))
    print(f"Ratings: {rating_count} total ({rating_parts})")

    # Timeline
    print(f"Timeline events: {timeline_count}")

    # Top sessions
    if top_sessions_enriched:
        print()
        print("Most active sessions (top 5):")
        for i, s in enumerate(top_sessions_enriched, 1):
            print(f"  {i}. {s['display_name']} ({s['role']}, {s['runtime']}) — {s['ops']} ops")

    return 0


def cmd_export(args: argparse.Namespace) -> int:
    """Export ~/.aids records with metadata in JSON, JSONL, or flat CSV."""
    ensure_layout()
    dd = data_dir()
    fmt = getattr(args, "format", "json") or "json"
    type_name = getattr(args, "type", "all") or "all"
    session_filter = getattr(args, "session", None)
    resource_filter = _normalize_export_resource(getattr(args, "resource", None))

    try:
        date_from, date_to = _export_date_range(args)
        type_names = _export_type_names(type_name)
    except ValueError as exc:
        print(f"aids export: {exc}", file=sys.stderr)
        return 2

    if fmt == "csv" and (len(type_names) != 1 or type_names[0] not in CSV_EXPORT_TYPES):
        allowed = ", ".join(sorted(CSV_EXPORT_TYPES))
        print(f"aids export: CSV output is only supported for one flat type: {allowed}", file=sys.stderr)
        return 2

    data: Dict[str, List[Dict[str, Any]]] = {
        kind: _load_export_records(dd, kind, date_from, date_to, session_filter, resource_filter)
        for kind in type_names
    }
    counts = {kind: len(records) for kind, records in data.items()}
    metadata = _export_metadata(
        dd, fmt, type_name, type_names, date_from, date_to,
        session_filter, resource_filter, counts,
    )

    output_path = getattr(args, "output", None)
    out, should_close = _open_export_output(output_path)
    try:
        if fmt == "json":
            payload: Dict[str, Any] = {"metadata": metadata}
            payload["data"] = data if type_name == "all" else data[type_names[0]]
            out.write(json_dump(payload) + "\n")
        elif fmt == "jsonl":
            out.write(json_line({"metadata": metadata}) + "\n")
            for kind in type_names:
                for record in data[kind]:
                    if type_name == "all":
                        out.write(json_line({"type": kind, "record": record}) + "\n")
                    else:
                        out.write(json_line(record) + "\n")
        elif fmt == "csv":
            kind = type_names[0]
            records = data[kind]
            columns = _csv_columns(kind, records)
            meta_columns = [
                "export_schema_version", "exported_at", "export_type",
                "date_from", "date_to", "record_count", "data_dir",
            ]
            writer = csv.writer(out)
            writer.writerow(meta_columns + columns)
            meta_values = [
                metadata["schema_version"], metadata["exported_at"], kind,
                date_from or "", date_to or "", metadata["record_count"], str(dd),
            ]
            for record in records:
                writer.writerow(meta_values + [_csv_value(record.get(c)) for c in columns])
    finally:
        if should_close:
            out.close()

    return 0


def cmd_doctor(args: argparse.Namespace) -> int:
    ensure_layout()
    checks = []
    checks.append(check("data_dir", data_dir().exists(), str(data_dir())))
    checks.append(check("sessions_dir", (data_dir() / "sessions").exists(), str(data_dir() / "sessions")))
    checks.append(check("traces_dir", (data_dir() / "traces").exists(), str(data_dir() / "traces")))
    claude_settings = Path(os.environ.get("CLAUDE_HOME", str(Path.home() / ".claude"))) / "settings.json"
    codex_hooks = Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex"))) / "hooks.json"
    codex_config = Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex"))) / "config.toml"
    checks.append(check("claude_settings", file_contains(claude_settings, "selftools") or file_contains(claude_settings, "aids"), str(claude_settings)))
    checks.append(check("codex_hooks", file_contains(codex_hooks, "selftools") or file_contains(codex_hooks, "aids"), str(codex_hooks)))
    checks.append(check("codex_mcp", file_contains(codex_config, "mcp_servers.selftools") or file_contains(codex_config, "mcp_servers.aids"), str(codex_config)))
    lock_mech = "fcntl.flock" if fcntl is not None else "windows/msvcrt"
    checks.append(check("lock_mechanism", True, lock_mech))
    locks_dir = data_dir() / "locks"
    stale_count = sum(1 for _ in locks_dir.glob("*.lock")) if locks_dir.exists() else 0
    checks.append(check("locks_dir", locks_dir.exists(), f"{locks_dir} ({stale_count} lock files)"))
    if args.json:
        print(json_dump({"ok": all(c["ok"] for c in checks[:3]), "checks": checks}))
    else:
        print(f"{ZH_NAME} doctor")
        for c in checks:
            mark = "✅" if c["ok"] else "⚠️ "
            print(f"{mark} {c['name']}: {c['detail']}")
    return 0 if all(c["ok"] for c in checks[:3]) else 1


def check(name: str, ok: bool, detail: str) -> Dict[str, Any]:
    return {"name": name, "ok": bool(ok), "detail": detail}


def file_contains(path: Path, needle: str) -> bool:
    try:
        return needle in path.read_text(encoding="utf-8")
    except Exception:
        return False


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="aids", description="AIDS (Agent-ID System) identity-aware trace CLI")
    p.add_argument("--data-dir", help="Override ~/.aids data dir for this invocation")
    sub = p.add_subparsers(dest="cmd", required=True)

    hook = sub.add_parser("hook", help="Run hook handler")
    hook_sub = hook.add_subparsers(dest="hook_cmd", required=True)
    hook_sub.add_parser("session-start").set_defaults(func=cmd_hook_session_start)
    hook_sub.add_parser("pre-tool-use").set_defaults(func=cmd_hook_pre_tool_use)
    hook_sub.add_parser("post-tool-use").set_defaults(func=cmd_hook_post_tool_use)

    reg = sub.add_parser("register-session", help="Register/update a session identity")
    reg.add_argument("--session-id")
    reg.add_argument("--runtime", choices=["claude", "codex", "bash", "unknown"])
    reg.add_argument("--role")
    reg.add_argument("--goal")
    reg.add_argument("--display-name")
    reg.add_argument("--team-id")
    reg.add_argument("--task-id")
    reg.add_argument("--model")
    reg.add_argument("--cwd")
    reg.set_defaults(func=cmd_register_session)

    sess = sub.add_parser("session-info", help="Lookup a session")
    sess.add_argument("session_id")
    sess.add_argument("--json", action="store_true")
    sess.set_defaults(func=cmd_session_info)

    retire = sub.add_parser("retire-session", help="Mark a session as retired")
    retire.add_argument("session_id")
    retire.add_argument("--reason", help="Reason for retirement")
    retire.add_argument("--json", action="store_true")
    retire.set_defaults(func=cmd_retire_session)

    ls = sub.add_parser("list-sessions", help="List registered sessions")
    ls.add_argument("--status", choices=["active", "retired", "archived"], help="Filter by status")
    ls.add_argument("--role", help="Filter by role")
    ls.add_argument("--runtime", choices=["claude", "codex", "bash", "unknown"], help="Filter by runtime")
    ls.add_argument("--json", action="store_true")
    ls.set_defaults(func=cmd_list_sessions)

    hb = sub.add_parser("heartbeat", help="Bump session last_seen_at")
    hb.add_argument("session_id")
    hb.add_argument("--json", action="store_true")
    hb.set_defaults(func=cmd_heartbeat)

    wi = sub.add_parser("whois", help="Human-readable session summary")
    wi.add_argument("session_id")
    wi.add_argument("--json", action="store_true")
    wi.set_defaults(func=cmd_whois)

    wt = sub.add_parser("who-touched", help="Show recent operations for a file/resource")
    wt.add_argument("path")
    wt.add_argument("--limit", type=int, default=RECENT_LIMIT)
    wt.add_argument("--json", action="store_true")
    wt.set_defaults(func=cmd_who_touched)

    oc = sub.add_parser("op-chain", help="Show operation chain for a file/resource")
    oc.add_argument("path")
    oc.add_argument("--limit", type=int, default=50)
    oc.add_argument("--json", action="store_true")
    oc.set_defaults(func=cmd_op_chain)

    rate = sub.add_parser("rate", help="Rate a trace operation")
    rate.add_argument("trace_id")
    rate.add_argument("score", choices=["good", "bad", "neutral", "uncertain"])
    rate.add_argument("comment", nargs="*")
    rate.set_defaults(func=cmd_rate)


    tl = sub.add_parser("timeline", help="Show recent timeline events")
    tl.add_argument("--limit", type=int, default=20)
    tl.add_argument("--json", action="store_true")
    tl.set_defaults(func=cmd_timeline)

    stats = sub.add_parser("stats", help="Show aggregated statistics")
    stats.add_argument("--json", action="store_true", help="JSON output")
    stats.add_argument("--days", type=int, default=7, help="Lookback window in days (default: 7)")
    stats.add_argument("--all", action="store_true", dest="all", help="All time, ignore --days")
    stats.add_argument("--from", dest="from_date", help="Start date YYYY-MM-DD")
    stats.add_argument("--to", dest="to_date", help="End date YYYY-MM-DD")
    stats.set_defaults(func=cmd_stats)

    export = sub.add_parser("export", help="Export AIDS data")
    export.add_argument("--format", choices=["json", "jsonl", "csv"], default="json", help="Output format (default: json)")
    export.add_argument("--type", choices=["traces", "timeline", "ratings", "sessions", "all"], default="all", help="Data type to export (default: all)")
    export.add_argument("--output", help="Write to file instead of stdout")
    export.add_argument("--days", type=int, help="Lookback window in days (default: all time)")
    export.add_argument("--all", action="store_true", dest="all", help="All time, ignore --days")
    export.add_argument("--from", dest="from_date", help="Start date YYYY-MM-DD")
    export.add_argument("--to", dest="to_date", help="End date YYYY-MM-DD")
    export.add_argument("--session", help="Filter by session_id")
    export.add_argument("--resource", help="Filter by resource path")
    export.set_defaults(func=cmd_export)

    doctor = sub.add_parser("doctor", help="Verify installation")
    doctor.add_argument("--json", action="store_true")
    doctor.set_defaults(func=cmd_doctor)
    return p


def main(argv: Optional[List[str]] = None) -> int:
    global DEFAULT_DATA_DIR
    parser = build_parser()
    args = parser.parse_args(argv)
    if getattr(args, "data_dir", None):
        DEFAULT_DATA_DIR = Path(args.data_dir).expanduser()
    try:
        return int(args.func(args))
    except BrokenPipeError:
        return 0
    except Exception as exc:
        append_log({"level": "error", "event": "cli_exception", "error": repr(exc)})
        print(f"aids error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
