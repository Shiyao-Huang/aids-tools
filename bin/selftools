def _whois_by_agent_id(agent_id: str, as_json: bool) -> int:
    """Aggregate all sessions sharing an agent_id into one identity view."""
    sessions = sorted(
        [s for s in _all_sessions() if s.get("agent_id") == agent_id],
        key=lambda s: s.get("started_at") or 0,
    )
    if not sessions:
        eprint_identity(f"No sessions found for agent: {agent_id}")
        return 1
    first = sessions[0]
    latest = max(sessions, key=lambda s: s.get("last_seen_at") or s.get("started_at") or 0)
    if as_json:
        print(json_dump({
            "agent_id": agent_id,
            "display_name": first.get("display_name"),
            "role": first.get("role"),
            "team_id": first.get("team_id"),
            "first_seen_at": first.get("started_at"),
            "latest_session": latest.get("session_id"),
            "session_count": len(sessions),
            "sessions": sessions,
        }))
        return 0
    first_ts = first.get("started_at") or 0
    first_iso = _dt.datetime.fromtimestamp(first_ts / 1000.0, tz=_dt.timezone.utc).isoformat() if first_ts else "(unknown)"
    latest_ago = round((now_ms() - (latest.get("last_seen_at") or latest.get("started_at") or now_ms())) / 60000)
    print(f"Agent: {agent_id}")
    print(f"  Name:         {first.get('display_name', '(unnamed)')}")
    print(f"  Role:         {first.get('role', '?')}")
    print(f"  Team:         {first.get('team_id', '(none)')}")
    print(f"  First seen:   {first_iso}")
    print(f"  Sessions:     {len(sessions)}")
    print(f"  Latest seen:  {latest_ago}m ago  ({latest.get('session_id')})")
    print(f"  Status:       {latest.get('status', '?')}")
    if len(sessions) > 1:
        print()
        print("  Session history:")
        for s in sessions:
            started = _dt.datetime.fromtimestamp((s.get("started_at") or 0) / 1000.0, tz=_dt.timezone.utc).isoformat()[:19]
            status = s.get("status", "?")
            rt = s.get("runtime", "?")
            print(f"    {s['session_id']}  {started}  {rt}  {status}")
    return 0


def cmd_whois(args: argparse.Namespace) -> int:
    ensure_layout()
    sid = args.session_id
    if sid.startswith("agent-"):
        return _whois_by_agent_id(sid, args.json)
    record = load_session(sid)
    if not record:
        eprint_identity(f"Unknown session: {sid}")
        return 1
    if args.json:
        print(json_dump(record))
        return 0
    age_min = round((now_ms() - (record.get("started_at") or now_ms())) / 60000)
    last = record.get("last_seen_at") or record.get("started_at") or now_ms()
    ago = round((now_ms() - last) / 60000)
    print(f"Session: {record.get('session_id')}")
    print(f"  Agent ID:     {record.get('agent_id', '(none)')}")
    print(f"  Role:         {record.get('role', '?')}")
    print(f"  Name:         {record.get('display_name', '(unnamed)')}")
    print(f"  Runtime:      {record.get('runtime', '?')}{('/' + record['model']) if record.get('model') else ''}")
    print(f"  Goal:         {record.get('goal', '(none)')}")
    print(f"  Task:         {record.get('task_id', '(none)')}")
    print(f"  Team:         {record.get('team_id', '(none)')}")
    print(f"  Project:      {record.get('project_path', '(none)')}")
    print(f"  Status:       {record.get('status', '?')}")
    print(f"  Uptime:       {age_min}m")
    print(f"  Last seen:    {ago}m ago")
    return 0


def cmd_register_session(args: argparse.Namespace) -> int:
    event = {
        "session_id": args.session_id or env_first("AIDS_SESSION_ID", "AID_SESSION_ID", "SESSION_ID", "SELFTOOLS_SESSION_ID", "ZHUYI_SESSION_ID") or new_id("sess"),
        "cwd": args.cwd or os.getcwd(),
        "model": args.model,
    }
    # Supply env-like overrides through process env to keep one code path.
    if args.runtime:
        os.environ["AIDS_RUNTIME"] = args.runtime
    if args.role:
        os.environ["AIDS_ROLE"] = args.role
    if args.goal:
        os.environ["AIDS_INTENT"] = args.goal
    if args.team_id:
        os.environ["AIDS_TEAM_ID"] = args.team_id
    if args.task_id:
        os.environ["AIDS_TASK_ID"] = args.task_id
    if args.display_name:
        os.environ["AIDS_DISPLAY_NAME"] = args.display_name
    record = register_session(event, source="cli")
    print(json_dump(record))
    return 0


def cmd_rate(args: argparse.Namespace) -> int:
    ensure_layout()
    trace = read_trace(args.trace_id)
    if trace is None:
        eprint_identity(f"Trace not found: {args.trace_id}")
        return 1
    rater = env_first("AIDS_SESSION_ID", "AID_SESSION_ID", "SESSION_ID", "SELFTOOLS_SESSION_ID", "ZHUYI_SESSION_ID") or "anonymous"
    # INV-7: reject duplicate (trace_id, rater_session_id) ratings
    ratings_dir = data_dir() / "ratings"
    if ratings_dir.exists():
        for rf in sorted(ratings_dir.glob("*.jsonl")):
            for line in rf.read_text().strip().splitlines():
                if not line.strip():
                    continue
                try:
                    existing = json.loads(line)
                except (json.JSONDecodeError, ValueError):
                    continue
                if existing.get("trace_id") == args.trace_id and existing.get("rater_session_id") == rater:
                    eprint_identity(f"Already rated by {rater}: {args.trace_id}")
                    return 1
    rating = {
        "rating_id": new_id("rt"),
        "trace_id": args.trace_id,
        "rater_session_id": rater,
        "score": args.score,
        "comment": " ".join(args.comment).strip(),
        "context": env_first("AIDS_INTENT", "AID_INTENT", "INTENT", "SELFTOOLS_INTENT", "ZHUYI_INTENT"),
        "timestamp": now_ms(),
        "timestamp_iso": iso_now(),
        "runtime": env_first("AIDS_RUNTIME", "AID_RUNTIME", "SELFTOOLS_RUNTIME", "ZHUYI_RUNTIME") or "unknown",
        "rater_actor_type": env_first("AIDS_ACTOR_TYPE", "AID_ACTOR_TYPE", "SELFTOOLS_ACTOR_TYPE", "ZHUYI_ACTOR_TYPE") or "unknown",
    }
    append_jsonl(data_dir() / "ratings" / f"{today()}.jsonl", rating)
    print(json_dump(rating))
    return 0


def cmd_timeline(args: argparse.Namespace) -> int:
    ensure_layout()
    tl_file = timeline_file_for_today()
    if not tl_file.exists():
        eprint_identity("No timeline events today.")
        return 1
    events = [json.loads(l) for l in tl_file.read_text().strip().splitlines() if l.strip()]
    events = events[-args.limit:]
    if args.json:
        print(json_dump({"count": len(events), "events": events}))
        return 0
    for ev in events:
        ts = ev.get("timestamp_iso", "?")
        tool = ev.get("tool", "?")
        sid = str(ev.get("session_id", "?"))[:8]
        res = str(ev.get("resource", ev.get("resource_path", "")))[:60]
        runtime = ev.get("runtime", "?")
        actor = ev.get("actor_type", "?")
        print(f"{ts[11:19]} {actor}/{runtime} {sid} {tool} {res}")
    return 0


def _date_range(args: argparse.Namespace) -> Tuple[Optional[str], Optional[str]]:
    """Return (date_from, date_to) strings in YYYY-MM-DD, respecting --from/--to/--all."""
    if getattr(args, "all", False):
        return None, None
    date_from = getattr(args, "from_date", None)
    date_to = getattr(args, "to_date", None)
    if not date_from and not date_to:
        days = getattr(args, "days", 7)
        to = _dt.date.today()
        frm = to - _dt.timedelta(days=days - 1)
        return frm.strftime("%Y-%m-%d"), to.strftime("%Y-%m-%d")
    return date_from, date_to


def _jsonl_files_in_range(directory: Path, date_from: Optional[str], date_to: Optional[str]) -> List[Path]:
    """Return JSONL files in directory whose YYYY-MM-DD name falls within range."""
    if not directory.exists():
        return []
    out: List[Path] = []
    for f in sorted(directory.glob("*.jsonl")):
        stem = f.stem  # e.g. 2025-05-18
        if len(stem) == 10 and stem[4] == "-" and stem[7] == "-":
            if date_from and stem < date_from:
                continue
            if date_to and stem > date_to:
                continue
        out.append(f)
    return out


def _iter_jsonl_lines(files: List[Path]) -> Iterable[Dict[str, Any]]:
    for f in files:
        try:
            text = f.read_text(encoding="utf-8")
        except (FileNotFoundError, PermissionError):
            continue
        for line in text.splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                yield json.loads(line)
            except json.JSONDecodeError:
                continue


EXPORT_SCHEMA_VERSION = "aids.export.v1"
EXPORT_TYPES = ("traces", "timeline", "ratings", "sessions")
CSV_EXPORT_TYPES = {"traces", "timeline"}


def _validate_date_string(value: Optional[str], label: str) -> Optional[str]:
    if not value:
        return None
    try:
        _dt.date.fromisoformat(value)
    except ValueError as exc:
        raise ValueError(f"{label} must be YYYY-MM-DD: {value}") from exc
    return value


def _export_date_range(args: argparse.Namespace) -> Tuple[Optional[str], Optional[str]]:
    """Return export date range; default export is all-time unless --days is set."""
    if getattr(args, "all", False):
        return None, None
    date_from = _validate_date_string(getattr(args, "from_date", None), "--from")
    date_to = _validate_date_string(getattr(args, "to_date", None), "--to")
    if not date_from and not date_to and getattr(args, "days", None):
        days = max(1, int(getattr(args, "days")))
        to = _dt.date.today()
        frm = to - _dt.timedelta(days=days - 1)
        date_from, date_to = frm.isoformat(), to.isoformat()
    if date_from and date_to and date_from > date_to:
        raise ValueError(f"--from must be on or before --to: {date_from} > {date_to}")
    return date_from, date_to


def _record_date(record: Dict[str, Any]) -> Optional[str]:
    """Best-effort YYYY-MM-DD date from a session or loose record."""
    for key in ("timestamp_iso", "started_iso", "last_seen_iso"):
        value = record.get(key)
        if isinstance(value, str) and len(value) >= 10:
            try:
                return _dt.date.fromisoformat(value[:10]).isoformat()
            except ValueError:
                pass
    for key in ("timestamp", "started_at", "last_seen_at"):
        value = record.get(key)
        if isinstance(value, (int, float)):
            try:
                return _dt.datetime.fromtimestamp(value / 1000.0, tz=_dt.timezone.utc).date().isoformat()
            except (OverflowError, OSError, ValueError):
                pass
    return None


def _date_matches(record: Dict[str, Any], date_from: Optional[str], date_to: Optional[str]) -> bool:
    if not date_from and not date_to:
        return True
    rec_date = _record_date(record)
    if not rec_date:
        return False
    if date_from and rec_date < date_from:
        return False
    if date_to and rec_date > date_to:
        return False
    return True


def _export_type_names(type_name: str) -> List[str]:
    if type_name == "all":
        return list(EXPORT_TYPES)
    if type_name not in EXPORT_TYPES:
        raise ValueError(f"Unsupported export type: {type_name}")
    return [type_name]


def _normalize_export_resource(resource: Optional[str]) -> Optional[str]:
    if not resource:
        return None
    return normalize_resource(resource)


def _record_matches_filters(
    record: Dict[str, Any],
    kind: str,
    session_filter: Optional[str],
    resource_filter: Optional[str],
) -> bool:
    if session_filter:
        if kind == "ratings":
            if record.get("rater_session_id") != session_filter and record.get("session_id") != session_filter:
                return False
        elif record.get("session_id") != session_filter:
            return False
    if resource_filter:
        if kind not in {"traces", "timeline"}:
            return False
        resource_value = record.get("resource_path") or record.get("resource")
        if resource_value != resource_filter and _normalize_export_resource(str(resource_value or "")) != resource_filter:
            return False
    return True


def _load_session_export_records(
    sessions_dir: Path,
    date_from: Optional[str],
    date_to: Optional[str],
    session_filter: Optional[str],
) -> List[Dict[str, Any]]:
    if not sessions_dir.exists():
        return []
    records: List[Dict[str, Any]] = []
    for f in sorted(sessions_dir.glob("*.json")):
        rec = read_json(f, {})
        if not isinstance(rec, dict) or not rec:
            continue
        if session_filter and rec.get("session_id") != session_filter:
            continue
        if not _date_matches(rec, date_from, date_to):
            continue
        records.append(rec)
    return records


def _load_export_records(
    dd: Path,
    kind: str,
    date_from: Optional[str],
    date_to: Optional[str],
    session_filter: Optional[str],
    resource_filter: Optional[str],
) -> List[Dict[str, Any]]:
    if kind == "sessions":
        if resource_filter:
            return []
        return _load_session_export_records(dd / "sessions", date_from, date_to, session_filter)

    directory = dd / kind
    files = _jsonl_files_in_range(directory, date_from, date_to)
    return [
        rec
        for rec in _iter_jsonl_lines(files)
        if _record_matches_filters(rec, kind, session_filter, resource_filter)
    ]


def _export_metadata(
    dd: Path,
    fmt: str,
    type_name: str,
    type_names: List[str],
    date_from: Optional[str],
    date_to: Optional[str],
    session_filter: Optional[str],
    resource_filter: Optional[str],
    counts: Dict[str, int],
) -> Dict[str, Any]:
    total = sum(counts.values())
    return {
        "schema_version": EXPORT_SCHEMA_VERSION,
        "exported_at": iso_now(),
        "data_dir": str(dd),
        "format": fmt,
        "type": type_name,
        "types": type_names,
        "date_range": {"from": date_from, "to": date_to},
        "filters": {"session": session_filter, "resource": resource_filter},
        "record_count": total,
        "record_counts": counts,
    }


def _open_export_output(output_path: Optional[str]) -> Tuple[Any, bool]:
    if not output_path or output_path == "-":
        return sys.stdout, False
    path = Path(output_path).expanduser()
    path.parent.mkdir(parents=True, exist_ok=True)
    return open(path, "w", encoding="utf-8", newline=""), True


def _csv_value(value: Any) -> Any:
    if value is None:
        return ""
    if isinstance(value, (dict, list)):
        return json_line(value)
    return value


def _csv_columns(kind: str, records: List[Dict[str, Any]]) -> List[str]:
    preferred = {
        "traces": [
            "trace_id", "timestamp_iso", "timestamp", "session_id", "display_name",
            "role", "runtime", "actor_type", "tool", "operation", "resource_path",
            "intent", "pre_hash", "post_hash", "duration_ms", "team_id", "cwd",
            "tool_use_id", "timeline_path",
        ],
        "timeline": [
            "event_id", "trace_id", "parent_trace_id", "timestamp_iso", "timestamp",
            "session_id", "role", "runtime", "actor_type", "tool", "operation",
            "resource", "intent",
        ],
    }[kind]
    seen = set(preferred)
    extras = sorted(
        key
        for rec in records
        for key in rec.keys()
        if key not in seen and not isinstance(rec.get(key), (dict, list))
    )
    return preferred + extras


QUERY_SCHEMA_VERSION = "aids.query.v1"
DEFAULT_QUERY_CONFIG: Dict[str, Any] = {
    "query": {
        "enabled_modules": ["identity", "history", "signature", "impact", "ratings"],
        "default_limit": 5,
        "compact": True,
    },
    "output": {"max_chars": 1200, "intent_max": 80},
    "signature": {"enabled": True, "strategy": "hash_chain"},
    "impact": {"enabled": True, "provider": "gitnexus", "fallback": "grep"},
}

# Protected config keys — agents cannot override these.
PROTECTED_CONFIG_KEYS: Dict[str, Any] = {
    "signature.enabled": True,
    "signature.strategy": "hash_chain",
    "impact.enabled": True,
}
QUERY_MODULE_ALIASES = {"file_chain": "history"}


def _enforce_protected_config(config: Dict[str, Any]) -> Dict[str, Any]:
    """Override user config values that are security-protected."""
    for dotted, required in PROTECTED_CONFIG_KEYS.items():
        parts = dotted.split(".")
        obj = config
        for part in parts[:-1]:
            child = obj.get(part) if isinstance(obj, dict) else None
            if not isinstance(child, dict):
                obj[part] = {}
            obj = obj[part]
        key = parts[-1]
        if obj.get(key) != required:
            obj[key] = required
    return config


def _deep_copy_jsonable(value: Any) -> Any:
    return json.loads(json.dumps(value))


def _deep_merge_dict(base: Dict[str, Any], override: Dict[str, Any], _path: str = "") -> Dict[str, Any]:
    """Deep-merge override into base, skipping PROTECTED_CONFIG_KEYS."""
    merged = _deep_copy_jsonable(base)
    for key, value in override.items():
        full_path = f"{_path}.{key}" if _path else key
        if full_path in PROTECTED_CONFIG_KEYS:
            continue
        if isinstance(value, dict) and isinstance(merged.get(key), dict):
            merged[key] = _deep_merge_dict(merged[key], value, full_path)
        else:
            merged[key] = value
    return merged


def load_aids_config() -> Dict[str, Any]:
    """Load ~/.aids/config.json and merge it over built-in defaults."""
    path = data_dir() / "config.json"
    raw = read_json(path, {})
    if isinstance(raw, dict):
        merged = _deep_merge_dict(DEFAULT_QUERY_CONFIG, raw)
        return _enforce_protected_config(merged)
    return _deep_copy_jsonable(DEFAULT_QUERY_CONFIG)


def _split_csv_words(value: Any) -> List[str]:
    if not value:
        return []
    if isinstance(value, str):
        parts = re.split(r"[,\s]+", value)
    elif isinstance(value, list):
        parts = [str(v) for v in value]
    else:
        parts = [str(value)]
    return [p.strip() for p in parts if p and p.strip()]


def _normalize_query_module(name: str) -> str:
    clean = str(name or "").strip()
    return QUERY_MODULE_ALIASES.get(clean, clean)


def _query_limit(args: argparse.Namespace, config: Dict[str, Any]) -> int:
    if getattr(args, "limit", None):
        return max(1, int(args.limit))
    qcfg = config.get("query") if isinstance(config.get("query"), dict) else {}
    try:
        return max(1, int(qcfg.get("default_limit") or RECENT_LIMIT))
    except (TypeError, ValueError):
        return RECENT_LIMIT


def _query_enabled_modules(args: argparse.Namespace, config: Dict[str, Any]) -> List[str]:
    qcfg = config.get("query") if isinstance(config.get("query"), dict) else {}
    if getattr(args, "include", None):
        modules = _split_csv_words(args.include)
    else:
        modules = _split_csv_words(qcfg.get("enabled_modules") or DEFAULT_QUERY_CONFIG["query"]["enabled_modules"])
    exclude = set(_normalize_query_module(m) for m in _split_csv_words(getattr(args, "exclude", None)))
    out: List[str] = []
    for module in modules:
        name = _normalize_query_module(module)
        if name in exclude or name not in QUERY_RESOLVERS:
            continue
        if name not in out:
            out.append(name)
    return out


def _query_text(args: argparse.Namespace) -> str:
    raw = getattr(args, "target", "")
    if isinstance(raw, list):
        return " ".join(str(x) for x in raw).strip()
    return str(raw or "").strip()


def _query_tokens(query: str) -> List[str]:
    return [tok.strip(" \t\r\n'\"`，,。:：;；()[]{}<>") for tok in query.split() if tok.strip()]


def read_rating(rating_id: str) -> Optional[Dict[str, Any]]:
    for rating in _iter_jsonl_lines(_jsonl_files_in_range(data_dir() / "ratings", None, None)):
        if rating.get("rating_id") == rating_id:
            return rating
    return None


def ratings_for_trace(trace_id: str) -> List[Dict[str, Any]]:
    return [
        rating
        for rating in _iter_jsonl_lines(_jsonl_files_in_range(data_dir() / "ratings", None, None))
        if rating.get("trace_id") == trace_id
    ]


def session_traces(session_id: str, limit: int) -> List[Dict[str, Any]]:
    traces = [
        trace
        for trace in _iter_jsonl_lines(_jsonl_files_in_range(data_dir() / "traces", None, None))
        if trace.get("session_id") == session_id
    ]
    traces.sort(key=lambda tr: int(tr.get("timestamp") or 0))
    return traces[-limit:]


def _all_sessions() -> List[Dict[str, Any]]:
    sessions_dir = data_dir() / "sessions"
    if not sessions_dir.exists():
        return []
    out = []
    for path in sorted(sessions_dir.glob("*.json")):
        rec = read_json(path, {})
        if isinstance(rec, dict) and rec:
            out.append(rec)
    return out


def _compact_trace(trace: Dict[str, Any], intent_max: int = 80) -> Dict[str, Any]:
    return {
        "trace_id": trace.get("trace_id") or trace.get("traceId"),
        "timestamp_iso": trace.get("timestamp_iso") or trace.get("timestamp"),
        "operation": trace.get("operation"),
        "tool": trace.get("tool"),
        "session_id": trace.get("session_id") or trace.get("sessionId"),
        "agent_id": trace.get("agent_id"),
        "role": trace.get("role"),
        "runtime": trace.get("runtime"),
        "resource_path": trace.get("resource_path") or trace.get("filePath"),
        "intent": short(trace.get("intent") or trace.get("purpose"), intent_max),
    }


def detect_query_target(query: str) -> Dict[str, Any]:
    tokens = _query_tokens(query)
    probe = tokens[0] if tokens else ""
    for tok in tokens:
        if tok.startswith("tr_"):
            return {"kind": "trace", "query": query, "id": tok, "record": read_trace(tok)}
        if tok.startswith("rt_"):
            return {"kind": "rating", "query": query, "id": tok, "record": read_rating(tok)}
        if tok.startswith("agent-"):
            sessions = [s for s in _all_sessions() if s.get("agent_id") == tok]
            if sessions:
                return {"kind": "agent", "query": query, "id": tok, "sessions": sessions}

    for tok in tokens:
        session = load_session(tok)
        if session:
            return {"kind": "session", "query": query, "id": tok, "record": session}

    for tok in tokens:
        p = Path(tok).expanduser()
        resource = normalize_resource(tok)
        if p.exists() or load_index(resource).get("trace_ids"):
            return {"kind": "file", "query": query, "id": tok, "resource": resource, "exists": p.exists()}

    return {"kind": "unknown", "query": query, "id": probe}


def _fuzzy_sessions(query: str, limit: int) -> List[Dict[str, Any]]:
    needle = query.lower()
    matches = []
    for session in _all_sessions():
        hay = " ".join(str(session.get(k) or "") for k in ("session_id", "display_name", "role", "goal", "task_id", "agent_id")).lower()
        if needle and needle in hay:
            matches.append(session)
    return matches[:limit]


def _fuzzy_traces(query: str, limit: int) -> List[Dict[str, Any]]:
    needle = query.lower()
    matches = []
    for trace in _iter_jsonl_lines(_jsonl_files_in_range(data_dir() / "traces", None, None)):
        hay = " ".join(str(trace.get(k) or "") for k in ("trace_id", "session_id", "resource_path", "intent", "tool", "operation")).lower()
        if needle and needle in hay:
            matches.append(trace)
    matches.sort(key=lambda tr: int(tr.get("timestamp") or 0))
    return matches[-limit:]


def resolve_identity(target: Dict[str, Any], ctx: Dict[str, Any]) -> Dict[str, Any]:
    limit = int(ctx["limit"])
    record = target.get("record") if isinstance(target.get("record"), dict) else {}
    sessions: List[Dict[str, Any]] = []
    if target["kind"] == "session" and record:
        sessions.append(record)
    elif target["kind"] == "trace" and record:
        sid = str(record.get("session_id") or "")
        if sid:
            sessions.append(load_session(sid) or {"session_id": sid})
    elif target["kind"] == "rating" and record:
        sid = str(record.get("rater_session_id") or record.get("session_id") or "")
        if sid:
            sessions.append(load_session(sid) or {"session_id": sid})
    elif target["kind"] == "file":
        traces = recent_traces(str(target.get("resource")), limit=1)
        if traces:
            sid = str(traces[-1].get("session_id") or "")
            sessions.append(load_session(sid) or {"session_id": sid})
    elif target["kind"] == "agent":
        sessions.extend(target.get("sessions") or [])
    elif target["kind"] == "unknown":
        sessions.extend(_fuzzy_sessions(str(target.get("query") or ""), limit))

    current = current_session_id()
    items = []
    if current:
        items.append({"relation": "current", **(load_session(current) or {"session_id": current})})
    for session in sessions[:limit]:
        items.append({"relation": "target", **session})
    summary = "No matching identity found."
    if items:
        first = items[0]
        summary = f"{first.get('relation')}: {first.get('display_name') or first.get('session_id')} ({first.get('role', 'unknown')}/{first.get('runtime', 'unknown')})"
    return {"module": "identity", "status": "ok" if items else "no_data", "summary": summary, "items": items}


def resolve_history(target: Dict[str, Any], ctx: Dict[str, Any]) -> Dict[str, Any]:
    limit = int(ctx["limit"])
    intent_max = int(ctx["config"].get("output", {}).get("intent_max", 80))
    traces: List[Dict[str, Any]] = []
    if target["kind"] == "file":
        traces = recent_traces(str(target.get("resource")), limit=limit)
    elif target["kind"] == "trace" and target.get("record"):
        traces = [target["record"]]
    elif target["kind"] == "rating" and target.get("record"):
        trace = read_trace(str(target["record"].get("trace_id") or ""))
        traces = [trace] if trace else []
    elif target["kind"] == "session":
        traces = session_traces(str(target.get("id") or ""), limit)
    elif target["kind"] == "agent":
        agent_sessions = target.get("sessions") or []
        sids = [str(s.get("session_id") or "") for s in agent_sessions]
        all_traces: List[Dict[str, Any]] = []
        for sid in sids:
            all_traces.extend(session_traces(sid, limit))
        traces = all_traces[:limit]
    else:
        traces = _fuzzy_traces(str(target.get("query") or ""), limit)

    items = [_compact_trace(trace, intent_max=intent_max) for trace in traces if trace]
    summary = f"{len(items)} recent trace(s)." if items else "No matching history."
    return {"module": "history", "status": "ok" if items else "no_data", "summary": summary, "items": items}


def _signature_for_trace(trace: Dict[str, Any]) -> Dict[str, Any]:
    pre_hash = trace.get("pre_hash")
    post_hash = trace.get("post_hash")
    if pre_hash or post_hash:
        status = "hash_present"
    else:
        status = "unsigned"
    return {"trace_id": trace.get("trace_id"), "status": status, "pre_hash": pre_hash, "post_hash": post_hash}


def resolve_signature(target: Dict[str, Any], ctx: Dict[str, Any]) -> Dict[str, Any]:
    sig_cfg = ctx["config"].get("signature", {}) if isinstance(ctx["config"].get("signature"), dict) else {}
    if sig_cfg.get("enabled", True) is False:
        return {"module": "signature", "status": "disabled", "summary": "Signature module disabled.", "items": []}
    strategy = sig_cfg.get("strategy") or "hash_chain"
    limit = int(ctx["limit"])
    items: List[Dict[str, Any]] = []
    summary = "No signature target."
    if target["kind"] == "trace" and target.get("record"):
        items.append(_signature_for_trace(target["record"]))
    elif target["kind"] == "file":
        resource = str(target.get("resource"))
        traces = recent_traces(resource, limit=limit)
        items = [_signature_for_trace(trace) for trace in traces]
        current_hash = sha256_file(Path(resource))
        last_hash = traces[-1].get("post_hash") if traces else None
        if last_hash and current_hash:
            summary = "current file matches last recorded hash." if last_hash == current_hash else "current file differs from last recorded hash."
        elif items:
            summary = "recent traces found, but no comparable file hash."
    if not items and summary == "No signature target.":
        summary = "No signature/hash-chain evidence found."
    elif items and summary == "No signature target.":
        summary = f"{sum(1 for item in items if item.get('status') == 'hash_present')} trace hash signature(s) present."
    return {"module": "signature", "status": "ok" if items else "no_data", "summary": f"{strategy}: {summary}", "items": items}


def _grep_impact(resource: str, limit: int) -> Dict[str, Any]:
    basename = Path(resource).name
    if not basename:
        return {"provider": "grep", "matches": []}
    root = Path.cwd()
    ignored = {".git", ".aha", ".aids", "node_modules", "__pycache__"}
    matches = []
    scanned = 0
    for path in root.rglob("*"):
        if len(matches) >= limit:
            break
        if any(part in ignored for part in path.parts):
            continue
        if not path.is_file() or path.stat().st_size > 512_000:
            continue
        scanned += 1
        try:
            text = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        if basename in text:
            matches.append(str(path.relative_to(root)))
    return {"provider": "grep", "scanned_files": scanned, "matches": matches}


def resolve_impact(target: Dict[str, Any], ctx: Dict[str, Any]) -> Dict[str, Any]:
    impact_cfg = ctx["config"].get("impact", {}) if isinstance(ctx["config"].get("impact"), dict) else {}
    if impact_cfg.get("enabled", True) is False:
        return {"module": "impact", "status": "disabled", "summary": "Impact module disabled.", "items": []}
    limit = int(ctx["limit"])
    resource = ""
    if target["kind"] == "file":
        resource = str(target.get("resource") or "")
    elif target["kind"] == "trace" and target.get("record"):
        resource = str(target["record"].get("resource_path") or "")
    if not resource or resource.startswith(("bash:", "mcp:")):
        return {"module": "impact", "status": "no_data", "summary": "No file impact target.", "items": []}

    provider = impact_cfg.get("provider") or "gitnexus"
    items: List[Dict[str, Any]] = []
    summary = ""
    if provider == "gitnexus":
        gn = gitnexus_file_context(resource)
        if gn and gn.get("available") and "multiple repositories indexed" not in str(gn.get("summary", "")).lower():
            items.append(gn)
            summary = f"gitnexus importance={gn.get('importance')}"
        else:
            if gn:
                items.append(gn)
            provider = impact_cfg.get("fallback") or "grep"
    if provider == "grep":
        grep_result = _grep_impact(resource, limit)
        items.append(grep_result)
        summary = f"grep fallback found {len(grep_result.get('matches') or [])} reference(s)."
    return {"module": "impact", "status": "ok" if items else "no_data", "summary": summary or "No impact data.", "items": items}


def resolve_ratings(target: Dict[str, Any], ctx: Dict[str, Any]) -> Dict[str, Any]:
    limit = int(ctx["limit"])
    ratings: List[Dict[str, Any]] = []
    if target["kind"] == "trace":
        ratings = ratings_for_trace(str(target.get("id") or ""))
    elif target["kind"] == "rating" and target.get("record"):
        ratings = [target["record"]]
    elif target["kind"] == "file":
        traces = recent_traces(str(target.get("resource")), limit=limit)
        trace_ids = {str(trace.get("trace_id")) for trace in traces if trace.get("trace_id")}
        ratings = [
            rating
            for rating in _iter_jsonl_lines(_jsonl_files_in_range(data_dir() / "ratings", None, None))
            if rating.get("trace_id") in trace_ids
        ]
    elif target["kind"] == "session":
        sid = str(target.get("id") or "")
        ratings = [
            rating
            for rating in _iter_jsonl_lines(_jsonl_files_in_range(data_dir() / "ratings", None, None))
            if rating.get("rater_session_id") == sid or rating.get("session_id") == sid
        ]
    dist: Dict[str, int] = {}
    for rating in ratings:
        score = str(rating.get("score") or "unknown")
        dist[score] = dist.get(score, 0) + 1
    items = ratings[-limit:]
    summary = f"{len(ratings)} rating(s): {dist}" if ratings else "No ratings found."
    return {"module": "ratings", "status": "ok" if ratings else "no_data", "summary": summary, "distribution": dist, "items": items}


QUERY_RESOLVERS = {
    "identity": resolve_identity,
    "history": resolve_history,
    "signature": resolve_signature,
    "impact": resolve_impact,
    "ratings": resolve_ratings,
}


def _query_target_public(target: Dict[str, Any]) -> Dict[str, Any]:
    return {k: v for k, v in target.items() if k != "record"}


def format_query_text(payload: Dict[str, Any], *, full: bool, max_chars: int) -> str:
    icons = {"identity": "👤", "history": "📜", "signature": "✍️", "impact": "💥", "ratings": "⭐"}
    target = payload.get("target", {})
    lines = [f"🧭 AIDS query: {payload.get('query')} ({target.get('kind', 'unknown')})"]
    for result in payload.get("results", []):
        module = result.get("module")
        lines.append(f"{icons.get(module, '•')} {module}: {result.get('summary')}")
        if full:
            for item in result.get("items", [])[: payload.get("limit", RECENT_LIMIT)]:
                lines.append(f"  - {json_line(item)}")
    text = "\n".join(lines)
    if not full and max_chars > 0 and len(text) > max_chars:
        return text[: max_chars - 2].rstrip() + "…\n"
    return text + "\n"


def cmd_query(args: argparse.Namespace) -> int:
    ensure_layout()
    config = load_aids_config()
    query = _query_text(args)
    target = detect_query_target(query)
    limit = _query_limit(args, config)
    modules = _query_enabled_modules(args, config)
    ctx = {"config": config, "limit": limit, "full": bool(getattr(args, "full", False)), "query": query}
    results = []
    for module in modules:
        resolver = QUERY_RESOLVERS[module]
        try:
            results.append(resolver(target, ctx))
        except Exception as exc:
            results.append({"module": module, "status": "error", "summary": str(exc), "items": []})
    payload = {
        "schema_version": QUERY_SCHEMA_VERSION,
        "query": query,
        "target": _query_target_public(target),
        "limit": limit,
        "modules": modules,
        "results": results,
        "config_path": str(data_dir() / "config.json"),
    }
    if args.json:
        print(json_dump(payload))
    else:
        output_cfg = config.get("output") if isinstance(config.get("output"), dict) else {}
        max_chars = int(output_cfg.get("max_chars") or 1200)
        print(format_query_text(payload, full=bool(getattr(args, "full", False)), max_chars=max_chars), end="")
    return 0


def cmd_stats(args: argparse.Namespace) -> int:
    ensure_layout()
    dd = data_dir()
    date_from, date_to = _date_range(args)

    # ── Sessions ──
    sessions_dir = dd / "sessions"
    sessions: List[Dict[str, Any]] = []
    if sessions_dir.exists():
        for f in sessions_dir.glob("*.json"):
            rec = read_json(f, {})
            if rec:
                sessions.append(rec)

    # Filter sessions by date if needed
    if date_from or date_to:
        filtered = []
        for s in sessions:
            started = s.get("started_iso") or ""
            started_date = started[:10]  # YYYY-MM-DD
            if date_from and started_date and started_date < date_from:
                continue
            if date_to and started_date and started_date > date_to:
                continue
            filtered.append(s)
        sessions = filtered

    sess_total = len(sessions)
    sess_by_status: Dict[str, int] = {}
    sess_by_runtime: Dict[str, int] = {}
    sess_by_role: Dict[str, int] = {}
    for s in sessions:
        st = s.get("status") or "unknown"
        rt = s.get("runtime") or "unknown"
        rl = s.get("role") or "unknown"
        sess_by_status[st] = sess_by_status.get(st, 0) + 1
        sess_by_runtime[rt] = sess_by_runtime.get(rt, 0) + 1
        sess_by_role[rl] = sess_by_role.get(rl, 0) + 1

    # ── Traces ──
    trace_files = _jsonl_files_in_range(dd / "traces", date_from, date_to)
    trace_count = 0
    op_counts: Dict[str, int] = {}
    trace_by_session: Dict[str, int] = {}
    trace_by_runtime: Dict[str, int] = {}
    resource_counts: Dict[str, int] = {}
    for tr in _iter_jsonl_lines(trace_files):
        trace_count += 1
        op = tr.get("operation") or "unknown"
        op_counts[op] = op_counts.get(op, 0) + 1
        sid = tr.get("session_id") or "unknown"
        trace_by_session[sid] = trace_by_session.get(sid, 0) + 1
        rt = tr.get("runtime") or "unknown"
        trace_by_runtime[rt] = trace_by_runtime.get(rt, 0) + 1
        res = tr.get("resource_path") or "unknown"
        resource_counts[res] = resource_counts.get(res, 0) + 1

    # ── Timeline ──
    tl_files = _jsonl_files_in_range(dd / "timeline", date_from, date_to)
    timeline_count = sum(1 for _ in _iter_jsonl_lines(tl_files))

    # ── Ratings ──
    rating_files = _jsonl_files_in_range(dd / "ratings", date_from, date_to)
    rating_count = 0
    rating_dist: Dict[str, int] = {}
    for r in _iter_jsonl_lines(rating_files):
        rating_count += 1
        sc = r.get("score") or "unknown"
        rating_dist[sc] = rating_dist.get(sc, 0) + 1

    # ── Resources ──
    unique_resources = len(resource_counts)
    top_resources = sorted(resource_counts.items(), key=lambda x: -x[1])[:5]

    # ── Top 5 most active sessions ──
    top_sessions = sorted(trace_by_session.items(), key=lambda x: -x[1])[:5]
    # Enrich with session metadata
    top_sessions_enriched = []
    for sid, count in top_sessions:
        meta = load_session(sid)
        top_sessions_enriched.append({
            "session_id": sid,
            "ops": count,
            "role": (meta.get("role") or "unknown"),
            "runtime": (meta.get("runtime") or "unknown"),
            "display_name": (meta.get("display_name") or sid),
        })

    # ── Output ──
    if getattr(args, "json", False):
        result = {
            "date_range": {"from": date_from, "to": date_to},
            "sessions": {
                "total": sess_total,
                "by_status": sess_by_status,
                "by_runtime": sess_by_runtime,
                "by_role": sess_by_role,
            },
            "traces": {
                "total": trace_count,
                "by_operation": op_counts,
                "by_runtime": trace_by_runtime,
            },
            "resources": {
                "unique": unique_resources,
                "top": [{"path": p, "ops": c} for p, c in top_resources],
            },
            "timeline_events": timeline_count,
            "ratings": {
                "total": rating_count,
                "distribution": rating_dist,
            },
            "top_sessions": top_sessions_enriched,
        }
        print(json_dump(result))
        return 0

    # Human-readable
    range_label = f"{date_from or 'beginning'} → {date_to or 'now'}"
    print(f"AIDS Statistics ({range_label})")
    print()

    # Sessions
    status_parts = ", ".join(f"{k}: {v}" for k, v in sorted(sess_by_status.items()))
    runtime_parts = ", ".join(f"{k}: {v}" for k, v in sorted(sess_by_runtime.items()))
    print(f"Sessions: {sess_total} total ({status_parts})")
    print(f"  By runtime: {runtime_parts}")

    # Traces
    op_parts = ", ".join(f"{k}: {v}" for k, v in sorted(op_counts.items()))
    print(f"Traces:   {trace_count} total ({op_parts})")
    tr_runtime_parts = ", ".join(f"{k}: {v}" for k, v in sorted(trace_by_runtime.items()))
    if tr_runtime_parts:
        print(f"  By runtime: {tr_runtime_parts}")

    # Resources
    print(f"Resources touched: {unique_resources} unique")
    if top_resources:
        print("  Top resources:")
        for p, c in top_resources:
            display = p
            try:
                display = os.path.relpath(p)
            except Exception:
                pass
            display = short(display, 60)
            print(f"    {display} ({c} ops)")

    # Ratings
    rating_parts = ", ".join(f"{k}: {v}" for k, v in sorted(rating_dist.items()))
    print(f"Ratings: {rating_count} total ({rating_parts})")

    # Timeline
    print(f"Timeline events: {timeline_count}")

    # Top sessions
    if top_sessions_enriched:
        print()
        print("Most active sessions (top 5):")
        for i, s in enumerate(top_sessions_enriched, 1):
            print(f"  {i}. {s['display_name']} ({s['role']}, {s['runtime']}) — {s['ops']} ops")

    return 0


def cmd_export(args: argparse.Namespace) -> int:
    """Export ~/.aids records with metadata in JSON, JSONL, or flat CSV."""
    ensure_layout()
    dd = data_dir()
    fmt = getattr(args, "format", "json") or "json"
    type_name = getattr(args, "type", "all") or "all"
    session_filter = getattr(args, "session", None)
    resource_filter = _normalize_export_resource(getattr(args, "resource", None))

    try:
        date_from, date_to = _export_date_range(args)
        type_names = _export_type_names(type_name)
    except ValueError as exc:
        eprint_identity(f"aids export: {exc}")
        return 2

    if fmt == "csv" and (len(type_names) != 1 or type_names[0] not in CSV_EXPORT_TYPES):
        allowed = ", ".join(sorted(CSV_EXPORT_TYPES))
        eprint_identity(f"aids export: CSV output is only supported for one flat type: {allowed}")
        return 2

    data: Dict[str, List[Dict[str, Any]]] = {
        kind: _load_export_records(dd, kind, date_from, date_to, session_filter, resource_filter)
        for kind in type_names
    }
    counts = {kind: len(records) for kind, records in data.items()}
    metadata = _export_metadata(
        dd, fmt, type_name, type_names, date_from, date_to,
        session_filter, resource_filter, counts,
    )

    output_path = getattr(args, "output", None)
    out, should_close = _open_export_output(output_path)
    try:
        if fmt == "json":
            payload: Dict[str, Any] = {"metadata": metadata}
            payload["data"] = data if type_name == "all" else data[type_names[0]]
            out.write(json_dump(payload) + "\n")
        elif fmt == "jsonl":
            out.write(json_line({"metadata": metadata}) + "\n")
            for kind in type_names:
                for record in data[kind]:
                    if type_name == "all":
                        out.write(json_line({"type": kind, "record": record}) + "\n")
                    else:
                        out.write(json_line(record) + "\n")
        elif fmt == "csv":
            kind = type_names[0]
            records = data[kind]
            columns = _csv_columns(kind, records)
            meta_columns = [
                "export_schema_version", "exported_at", "export_type",
                "date_from", "date_to", "record_count", "data_dir",
            ]
            writer = csv.writer(out)
            writer.writerow(meta_columns + columns)
            meta_values = [
                metadata["schema_version"], metadata["exported_at"], kind,
                date_from or "", date_to or "", metadata["record_count"], str(dd),
            ]
            for record in records:
                writer.writerow(meta_values + [_csv_value(record.get(c)) for c in columns])
    finally:
        if should_close:
            out.close()

    return 0


# ────────────────────────────────────────────────────────────────
# CodeGraph — built-in code graph analysis (zero external deps)
# Parses Python ast + JS import/export + generic text refs
# Caches to ~/.aids/codegraph/{sha256(root)}.json
# ────────────────────────────────────────────────────────────────

CODEGRAPH_MAX_FILES = 5000
CODEGRAPH_MAX_CACHE_MB = 50
_GENERIC_SKIP_STEMS = frozenset({"index", "main", "app", "config", "utils", "helpers", "types", "constants"})


def _codegraph_cache_path(project_root: str) -> Path:
    h = hashlib.sha256(project_root.encode("utf-8")).hexdigest()[:16]
    return data_dir() / "codegraph" / f"{h}.json"


def _file_signature(path: Path) -> Optional[str]:
    try:
        st = path.stat()
        return f"{int(st.st_mtime)}:{st.st_size}"
    except OSError:
        return None


def _is_python_shebang(fp: Path) -> bool:
    """Check if a file starts with a Python shebang line."""
    try:
        with fp.open("r", encoding="utf-8", errors="replace") as f:
            first = f.readline(128)
        return first.startswith("#!") and "python" in first
    except (OSError, PermissionError):
        return False


def _collect_source_files(root: Path) -> Dict[str, str]:
    """Walk root and return {relative_path: mtime:size} for all source files."""
    sigs: Dict[str, str] = {}
    skip_dirs = {".git", "node_modules", "__pycache__", ".venv", "venv", ".tox",
                 "dist", "build", ".next", ".aids", ".gitnexus"}
    src_exts = {".py", ".js", ".ts", ".jsx", ".tsx", ".mjs", ".cjs"}
    count = 0
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if d not in skip_dirs and not d.startswith(".")]
        for fn in filenames:
            fp = Path(dirpath) / fn
            ext = os.path.splitext(fn)[1].lower()
            if ext not in src_exts:
                if ext == "" and _is_python_shebang(fp):
                    pass  # extensionless Python script (e.g. bin/selftools)
                else:
                    continue
            try:
                rel = str(fp.relative_to(root))
            except ValueError:
                continue
            try:
                rel = str(fp.relative_to(root))
            except ValueError:
                continue
            sig = _file_signature(fp)
            if sig:
                sigs[rel] = sig
                count += 1
                if count >= CODEGRAPH_MAX_FILES:
                    return sigs
    return sigs


def _parse_py_imports(source: str) -> List[str]:
    """Extract top-level module names from Python import statements via ast."""
    modules: List[str] = []
    try:
        tree = _ast.parse(source)
    except (SyntaxError, ValueError):
        return modules
    for node in _ast.walk(tree):
        if isinstance(node, _ast.Import):
            for alias in node.names:
                modules.append(alias.name.split(".")[0])
        elif isinstance(node, _ast.ImportFrom):
            if node.module:
                modules.append(node.module.split(".")[0])
    return list(dict.fromkeys(modules))


def _parse_py_exports(source: str) -> List[str]:
    """Extract top-level function and class names from Python source."""
    names: List[str] = []
    try:
        tree = _ast.parse(source)
    except (SyntaxError, ValueError):
        return names
    for node in _ast.iter_child_nodes(tree):
        if isinstance(node, (_ast.FunctionDef, _ast.AsyncFunctionDef)):
            names.append(node.name)
        elif isinstance(node, _ast.ClassDef):
            names.append(node.name)
    return names


def _parse_js_imports(source: str) -> List[str]:
    """Extract module specifiers from JS/TS import/require via re."""
    modules: List[str] = []
    for pat in [
        r"""(?:import|export)\s+(?:.*?)\s+from\s+['"\`]([^'"\`]+)['"\`]""",
        r"""import\s+['"\`]([^'"\`]+)['"\`]""",
        r"""require\s*\(\s*['"\`]([^'"\`]+)['"\`]\s*\)""",
    ]:
        for m in re.finditer(pat, source):
            mod = m.group(1)
            modules.append(mod.split("/")[0] if not mod.startswith(".") else mod)
    return list(dict.fromkeys(modules))


def _parse_js_exports(source: str) -> List[str]:
    """Extract exported names from JS/TS source via re."""
    names: List[str] = []
    for pat in [
        r"""export\s+(?:default\s+)?(?:function|const|let|var|class)\s+(\w+)""",
        r"""export\s+\{([^}]+)\}""",
        r"""module\.exports\s*=\s*\{([^}]+)\}""",
    ]:
        for m in re.finditer(pat, source):
            for name in re.findall(r"(\w+)", m.group(1)):
                if name not in {"as", "from", "default", "const", "let", "var", "function", "class"}:
                    names.append(name)
    return list(dict.fromkeys(names))


def _resolve_module(mod: str, from_file: str, root: Path) -> Optional[str]:
    """Resolve a module name to a relative file path under root."""
    if not mod.startswith("."):
        candidates = [
            mod.replace(".", "/") + ".py",
            mod.replace(".", "/") + "/__init__.py",
            mod + ".js", mod + ".ts",
            mod + "/index.js", mod + "/index.ts",
        ]
    else:
        base_dir = Path(from_file).parent
        base = mod.replace(".", "/").rstrip("/") or "."
        candidates = [str(c) for c in [
            base_dir / (base + ".py"), base_dir / (base + "/__init__.py"),
            base_dir / (base + ".js"), base_dir / (base + ".ts"),
            base_dir / base / "index.js", base_dir / base / "index.ts",
        ]]
    for cand in candidates:
        if (root / cand).exists():
            return cand
    return None


def analyze_project(root: Path, *, force: bool = False) -> Dict[str, Any]:
    """Analyze a project's code graph: imports, exports, dependencies.
    Caches to ~/.aids/codegraph/ and auto-refreshes on file changes.
    """
    ensure_layout()
    root_str = str(root.resolve())
    cache_path = _codegraph_cache_path(root_str)

    if not force and cache_path.exists():
        cached = read_json(cache_path, {})
        if cached and cached.get("root") == root_str:
            if (cached.get("file_signatures") or {}) == _collect_source_files(root):
                return cached

    sigs = _collect_source_files(root)
    files: Dict[str, Any] = {}
    sources: Dict[str, str] = {}

    for rel in sigs:
        fp = root / rel
        try:
            source = fp.read_text(encoding="utf-8", errors="replace")
        except (OSError, PermissionError):
            continue
        sources[rel] = source
        ext = os.path.splitext(rel)[1].lower()
        entry: Dict[str, Any] = {"imports": [], "exports": [], "resolved_deps": [], "imported_by": [], "refs": []}

        is_py = ext == ".py" or (ext == "" and source.startswith("#!") and "python" in source[:64])
        if is_py:
            entry["imports"] = _parse_py_imports(source)
            entry["exports"] = _parse_py_exports(source)
        elif ext in {".js", ".ts", ".jsx", ".tsx", ".mjs", ".cjs"}:
            entry["imports"] = _parse_js_imports(source)
            entry["exports"] = _parse_js_exports(source)

        for mod in entry["imports"]:
            resolved = _resolve_module(mod, rel, root)
            if resolved:
                entry["resolved_deps"].append(resolved)
        files[rel] = entry

    for rel, entry in files.items():
        for dep in entry.get("resolved_deps") or []:
            target = files.get(dep)
            if target and rel not in target.get("imported_by", []):
                target.setdefault("imported_by", [])
                target["imported_by"].append(rel)

    all_stems: Dict[str, str] = {}
    for rel in files:
        stem = Path(rel).stem
        if stem not in all_stems:
            all_stems[stem] = rel
    for rel, source in sources.items():
        for stem, stem_rel in all_stems.items():
            if stem_rel == rel or stem in _GENERIC_SKIP_STEMS:
                continue
            if re.search(r'\b' + re.escape(stem) + r'\b', source):
                entry = files[rel]
                if stem_rel not in entry.get("refs", []):
                    entry.setdefault("refs", [])
                    entry["refs"].append(stem_rel)

    graph = {
        "root": root_str,
        "file_signatures": sigs,
        "files": files,
        "meta": {"analyzed_at": iso_now(), "file_count": len(files), "analyzer_version": 1},
    }
    write_json_atomic(cache_path, graph)

    cg_dir = data_dir() / "codegraph"
    if cg_dir.exists():
        cached_files = sorted(cg_dir.glob("*.json"), key=lambda f: f.stat().st_mtime)
        total = sum(f.stat().st_size for f in cached_files)
        limit = CODEGRAPH_MAX_CACHE_MB * 1024 * 1024
        while total > limit and cached_files:
            oldest = cached_files.pop(0)
            total -= oldest.stat().st_size
            try:
                oldest.unlink()
            except OSError:
                pass

    return graph


def query_impact(graph: Dict[str, Any], file_path: str) -> Dict[str, Any]:
    """Query file impact from a code graph. Returns dependents, dependencies, importance."""
    files = graph.get("files") or {}
    target = None
    for rel in files:
        if rel == file_path or rel.endswith("/" + file_path) or file_path.endswith("/" + rel):
            target = rel
            break
    if not target:
        return {"file": file_path, "found": False, "dependents": [], "dependencies": []}

    entry = files[target]
    dependents = list(entry.get("imported_by") or [])
    dependencies = list(entry.get("resolved_deps") or [])
    refs_in = list(entry.get("refs") or [])

    for rel, fentry in files.items():
        if rel == target:
            continue
        if target in (fentry.get("resolved_deps") or []) and rel not in dependents:
            dependents.append(rel)

    dep_count = len(dependents)
    importance = "high" if dep_count >= 5 else ("medium" if dep_count >= 2 else "low")

    return {
        "file": target, "found": True, "importance": importance,
        "exports": entry.get("exports") or [],
        "dependents": dependents, "dependencies": dependencies,
        "references": refs_in, "dependent_count": dep_count,
    }


def builtin_file_impact(file_path: str, cwd: Optional[str] = None) -> Optional[Dict[str, Any]]:
    """Built-in file impact analysis for PreToolUse hook (replaces external gitnexus)."""
    try:
        root = Path(cwd or os.getcwd())
        for parent in [root] + list(root.parents):
            if (parent / ".git").exists():
                root = parent
                break

        fp = Path(file_path)
        if fp.is_absolute():
            try:
                file_rel = str(fp.relative_to(root))
            except ValueError:
                return None
        else:
            file_rel = file_path

        ext = os.path.splitext(file_rel)[1].lower()
        if ext not in {".py", ".js", ".ts", ".jsx", ".tsx", ".mjs", ".cjs", ""}:
            return None

        graph = analyze_project(root)
        return query_impact(graph, file_rel)
    except Exception:
        return None


def _fallback_grep_dependents(file_path: str, cwd: str) -> List[str]:
    """Find files that import/reference the given file using grep."""
    basename = Path(file_path).stem
    dependents: List[str] = []
    patterns = [
        f"import.*{basename}",
        f"require.*{basename}",
        f"from.*{basename}",
        f"#include.*{basename}",
    ]
    try:
        for pat in patterns:
            proc = subprocess.run(
                ["grep", "-rl", "--include=*.py", "--include=*.js", "--include=*.ts",
                 "--include=*.jsx", "--include=*.tsx", "--include=*.sh",
                 "-E", pat, cwd],
                text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
                timeout=10, check=False,
            )
            if proc.returncode == 0:
                for line in proc.stdout.strip().splitlines():
                    abs_path = str(Path(cwd) / line) if not Path(line).is_absolute() else line
                    if abs_path not in dependents and abs_path != str(Path(file_path).resolve()):
                        dependents.append(abs_path)
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return dependents


def _fallback_git_log(file_path: str, cwd: str, count: int = 5) -> List[Dict[str, Any]]:
    """Get recent git log entries for a file."""
    entries: List[Dict[str, Any]] = []
    try:
        rel = os.path.relpath(file_path, cwd)
    except Exception:
        rel = file_path
    try:
        proc = subprocess.run(
            ["git", "log", f"--max-count={count}", "--format=%H%n%an%n%ai%n%s", "--", rel],
            cwd=cwd, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
            timeout=10, check=False,
        )
        if proc.returncode == 0:
            chunks = proc.stdout.strip().split("\n\n")
            for chunk in chunks:
                lines = chunk.strip().splitlines()
                if len(lines) >= 4:
                    entries.append({
                        "hash": lines[0][:12],
                        "author": lines[1],
                        "date": lines[2][:10],
                        "message": lines[3],
                    })
    except (FileNotFoundError, subprocess.TimeoutExpired):
        pass
    return entries


def _fallback_grep_imports(file_path: str, cwd: str) -> List[str]:
    """Find what this file imports/references."""
    imports: List[str] = []
    try:
        with open(file_path, "r", encoding="utf-8", errors="ignore") as fh:
            content = fh.read(50000)
    except (FileNotFoundError, PermissionError):
        return imports
    for pat in [
        r'(?:import\s+(\S+))',
        r'(?:from\s+(\S+)\s+import)',
        r'(?:require\([\'"]([^\'"]+)[\'"]\))',
        r'(?:#include\s+[<"]([^>"]+)[>"])',
    ]:
        for m in re.finditer(pat, content):
            dep = m.group(1)
            if dep and dep not in imports:
                imports.append(dep)
    return imports[:30]


def _compute_importance(dependents: List[str], git_entries: List[Dict[str, Any]], traces: List[Dict[str, Any]]) -> str:
    """Heuristic importance: high if many dependents or recent high-frequency changes."""
    dep_score = min(len(dependents), 10)
    change_freq = len(git_entries)
    trace_freq = len(traces)
    if dep_score >= 5 or change_freq >= 4 or trace_freq >= 20:
        return "high"
    if dep_score >= 2 or change_freq >= 2 or trace_freq >= 5:
        return "medium"
    return "low"


def cmd_impact(args: argparse.Namespace) -> int:
    """Show file impact analysis: dependents, dependencies, importance, risk."""
    file_path = normalize_resource(args.path)
    cwd = str(os.getcwd())

    if not Path(file_path).exists() and not file_path.startswith(("bash:", "mcp:")):
        eprint_identity(f"File not found: {file_path}")
        return 1

    # ── Built-in CodeGraph analysis (AST + cached graph) ──
    builtin = builtin_file_impact(file_path, cwd)

    # ── External GitNexus (if installed) ──
    gn = gitnexus_file_context(file_path, cwd)

    # ── Fallback: grep-based detection ──
    grep_dependents = _fallback_grep_dependents(file_path, cwd)
    grep_dependencies = _fallback_grep_imports(file_path, cwd)

    # ── Merge: prefer built-in, augment with fallbacks ──
    if builtin and builtin.get("found"):
        dependents = builtin["dependents"]
        dependencies = builtin["dependencies"]
        importance = builtin["importance"]
        exports = builtin.get("exports", [])
        # Augment with grep results not already found
        for dep in grep_dependents:
            if dep not in dependents:
                dependents.append(dep)
        for dep in grep_dependencies:
            if dep not in dependencies:
                dependencies.append(dep)
    else:
        dependents = grep_dependents
        dependencies = grep_dependencies
        exports = []
        importance = "low"

    # Git log
    git_entries = _fallback_git_log(file_path, cwd, count=5)

    # AIDS traces for this file
    traces = recent_traces(file_path, limit=10)

    # Importance: upgrade if gitnexus or heuristic suggests higher
    heuristic = _compute_importance(dependents, git_entries, traces)
    for suggestion in [importance, heuristic, (gn.get("importance") if gn else None)]:
        if suggestion == "high":
            importance = "high"
            break
        if suggestion == "medium" and importance != "high":
            importance = "medium"

    result: Dict[str, Any] = {
        "file": file_path,
        "importance": importance,
        "exports": exports,
        "builtin_graph": builtin,
        "gitnexus": gn,
        "dependents": dependents[:20],
        "dependencies": dependencies[:20],
        "recent_git_changes": git_entries,
        "recent_traces": [
            {
                "trace_id": t.get("trace_id"),
                "operation": t.get("operation"),
                "by": (t.get("session") or {}).get("display_name") or t.get("session_id"),
                "role": (t.get("session") or {}).get("role"),
                "intent": t.get("intent"),
                "ago": human_ago(t.get("timestamp", 0)) if isinstance(t.get("timestamp"), int) else "unknown",
            }
            for t in traces
        ],
        "dependent_count": len(dependents),
        "dependency_count": len(dependencies),
        "risk_note": "",
    }

    # Risk assessment
    if importance == "high" and len(dependents) >= 3:
        result["risk_note"] = f"HIGH RISK: {len(dependents)} files depend on this. Changes have broad impact."
    elif importance == "medium":
        result["risk_note"] = f"MODERATE: {len(dependents)} dependent(s). Review before modifying."
    else:
        result["risk_note"] = "LOW: Few or no dependents detected."

    if getattr(args, "json", False):
        print(json_dump(result))
        return 0

    # Human-readable
    print(f"File Impact Analysis: {file_path}")
    print(f"  Importance: {importance.upper()}")
    print(f"  Risk:       {result['risk_note']}")
    print()

    if gn and gn.get("available"):
        print(f"  GitNexus: {short(gn.get('summary', ''), 200)}")
    elif gn:
        print(f"  GitNexus: {gn.get('summary', 'unavailable')}")
    else:
        print("  GitNexus: disabled or not installed")

    if builtin and builtin.get("found"):
        print(f"  Built-in code graph: {builtin.get('dependent_count', 0)} dependents, {len(builtin.get('exports', []))} exports")
    print()

    if dependents:
        print(f"  Dependents ({len(dependents)} files that import/reference this file):")
        for dep in dependents[:10]:
            try:
                display = os.path.relpath(dep, cwd)
            except Exception:
                display = dep
            print(f"    - {display}")
        if len(dependents) > 10:
            print(f"    ... and {len(dependents) - 10} more")
    else:
        print("  Dependents: none detected")
    print()

    if dependencies:
        print(f"  Dependencies ({len(dependencies)} imports):")
        for dep in dependencies[:10]:
            print(f"    - {dep}")
    print()

    if git_entries:
        print(f"  Recent git changes ({len(git_entries)}):")
        for e in git_entries:
            print(f"    - {e['date']} {e['author']}: {short(e['message'], 80)} ({e['hash']})")
    else:
        print("  Recent git changes: none (not in git or no history)")
    print()

    if traces:
        print(f"  Recent AIDS traces ({len(traces)}):")
        for t in traces:
            actor = (t.get("session") or {}).get("display_name") or t.get("session_id", "?")
            role = (t.get("session") or {}).get("role", "?")
            op = t.get("operation", "?")
            intent = short(t.get("intent", ""), 60)
            ago = human_ago(t.get("timestamp", 0)) if isinstance(t.get("timestamp"), int) else "?"
            print(f"    - {op} by {actor} ({role}) {ago}; intent: {intent}")
    else:
        print("  Recent AIDS traces: none")

    return 0


def cmd_commit_stamp(_: argparse.Namespace) -> int:
    """Output git Co-Authored-By trailer with current session identity."""
    sid = current_session_id() or "unknown"
    role = env_first("AIDS_ROLE", "AID_ROLE", "AHA_AGENT_ROLE", "ROLE", "SELFTOOLS_ROLE", "ZHUYI_ROLE", "AHA_ROLE") or "unknown"
    name = env_first("AIDS_DISPLAY_NAME", "AHA_SESSION_NAME", "AID_DISPLAY_NAME", "SELFTOOLS_DISPLAY_NAME", "ZHUYI_DISPLAY_NAME") or sid[:12]
    runtime = env_first("AIDS_RUNTIME", "AID_RUNTIME", "SELFTOOLS_RUNTIME", "ZHUYI_RUNTIME") or "unknown"
    print(f"Co-Authored-By: {name} ({role}/{runtime}) <aids:{sid}@agent>")
    return 0


def _verify_single_trace(target_trace_id: str, *, as_json: bool = False) -> int:
    """Verify a specific trace by replaying the chain up to that trace."""
    ensure_layout()
    traces_dir = data_dir() / "traces"
    if not traces_dir.exists():
        print(f"Trace {target_trace_id}: no traces directory.")
        return 1

    jsonl_files = sorted(traces_dir.glob("*.jsonl")) + sorted(traces_dir.glob("*.ndjson"))
    found: Optional[Dict[str, Any]] = None
    resource_traces: List[Dict[str, Any]] = []
    target_resource: Optional[str] = None

    for jf in jsonl_files:
        try:
            raw_lines = jf.read_text(encoding="utf-8").splitlines()
        except OSError:
            continue
        for raw_line in raw_lines:
            raw_line = raw_line.strip()
            if not raw_line:
                continue
            try:
                trace = json.loads(raw_line)
            except json.JSONDecodeError:
                continue
            tid = trace.get("trace_id")
            res = str(trace.get("resource_path") or "")
            if tid == target_trace_id:
                found = trace
                target_resource = res
            if target_resource and res == target_resource:
                resource_traces.append(trace)
            if found and tid == target_trace_id:
                break
        if found:
            break

    if not found:
        if as_json:
            print(json_dump({"trace_id": target_trace_id, "status": "not_found"}))
        else:
            print(f"\u274c {target_trace_id}: not found")
        return 1

    # Replay chain up to the target trace
    chain_state: Optional[str] = None
    for tr in resource_traces:
        if tr.get("trace_id") == target_trace_id:
            break
        chain_state = tr.get("chain_hash") or None

    stored_hash = found.get("chain_hash")
    if not stored_hash:
        result = {"trace_id": target_trace_id, "status": "legacy", "detail": "no chain_hash (legacy trace)"}
    elif _signature_backend.verify(found, chain_state, stored_hash):
        result = {"trace_id": target_trace_id, "status": "valid", "detail": "chain hash verified"}
    else:
        result = {"trace_id": target_trace_id, "status": "TAMPERED", "detail": "chain_hash mismatch: trace was tampered or chain broken"}

    if as_json:
        print(json_dump(result))
    else:
        mark = "\u2705" if result["status"] in ("valid", "legacy") else "\u274c"
        print(f"{mark} {result['trace_id']}: {result['detail']}")
    return 0 if result["status"] != "TAMPERED" else 1


def cmd_verify(args: argparse.Namespace) -> int:
    """Verify trace integrity: chain hash linkage and file hash consistency.

    If args.trace_id is given, verify only that specific trace.
    Otherwise, walk all trace JSONL files, recompute chain hashes, and flag any
    tampering or corruption.
    tampering or corruption.
    """
    target_trace_id = getattr(args, "trace_id", None)
    if target_trace_id:
        return _verify_single_trace(target_trace_id, as_json=getattr(args, "json", False))

    ensure_layout()
    traces_dir = data_dir() / "traces"
    if not traces_dir.exists():
        print("No traces directory found.")
        return 1

    # Collect all JSONL files sorted by date
    jsonl_files = sorted(traces_dir.glob("*.jsonl")) + sorted(traces_dir.glob("*.ndjson"))
    if not jsonl_files:
        print("No trace files found.")
        return 1

    total = 0
    ok_count = 0
    errors: List[Dict[str, Any]] = []
    # per-resource chain state: resource_path -> last verified chain_hash
    chain_state: Dict[str, Optional[str]] = {}
    # global chain: trace_id -> chain_hash (for cross-resource detection)
    global_prev_hash: Optional[str] = None

    for jf in jsonl_files:
        try:
            lines = jf.read_text(encoding="utf-8").splitlines()
        except OSError as exc:
            errors.append({"file": str(jf), "error": f"read error: {exc}"})
            continue
        for line_no, line in enumerate(lines, 1):
            line = line.strip()
            if not line:
                continue
            try:
                trace = json.loads(line)
            except json.JSONDecodeError as exc:
                errors.append({"file": str(jf), "line": line_no, "error": f"invalid JSON: {exc}"})
                continue
            total += 1
            resource = str(trace.get("resource_path") or "")
            stored_chain_hash = trace.get("chain_hash")

            # ── Check 1: chain hash linkage ──
            if stored_chain_hash:
                prev = chain_state.get(resource)
                expected_hash = _chain_hash_for_trace(trace, prev)
                if expected_hash != stored_chain_hash:
                    errors.append({
                        "file": str(jf), "line": line_no,
                        "trace_id": trace.get("trace_id"),
                        "resource": resource,
                        "error": "chain_hash mismatch: trace was tampered or chain broken",
                        "expected": expected_hash,
                        "stored": stored_chain_hash,
                    })
                else:
                    ok_count += 1
                chain_state[resource] = stored_chain_hash
            else:
                # No chain_hash field — legacy trace, skip chain check
                chain_state[resource] = None
                ok_count += 1

            # ── Check 2: file hash consistency (pre_hash matches previous post_hash) ──
            # This is checked per-resource for consecutive write traces

    # ── Check 3: protected config keys ──
    config = load_aids_config()
    config_violations = []
    for dotted, required in PROTECTED_CONFIG_KEYS.items():
        parts = dotted.split(".")
        obj = config
        for part in parts[:-1]:
            obj = obj.get(part, {}) if isinstance(obj, dict) else {}
        actual = obj.get(parts[-1]) if isinstance(obj, dict) else None
        if actual != required:
            config_violations.append({"key": dotted, "required": required, "actual": actual})

    # ── Output ──
    if getattr(args, "json", False):
        print(json_dump({
            "total_traces": total,
            "verified_ok": ok_count,
            "errors": errors,
            "config_violations": config_violations,
            "passed": len(errors) == 0 and len(config_violations) == 0,
        }))
    else:
        print(f"AIDS trace verification")
        print(f"  Total traces: {total}")
        print(f"  Verified OK: {ok_count}")
        print(f"  Errors: {len(errors)}")
        for err in errors[:20]:
            tid = err.get("trace_id", "?")
            print(f"    CHAIN BROKEN: {err.get('file', '?')}:{err.get('line', '?')} trace={tid}")
            print(f"      {err.get('error', '')}")
        if config_violations:
            print(f"  Config violations: {len(config_violations)}")
            for v in config_violations:
                print(f"    PROTECTED KEY: {v['key']} = {v['actual']!r} (required: {v['required']!r})")
        if not errors and not config_violations:
            print("  All traces verified. No tampering detected.")
    return 0 if (not errors and not config_violations) else 1


def cmd_doctor(args: argparse.Namespace) -> int:
    ensure_layout()
    checks: List[Dict[str, Any]] = []
    # ── Core data directories ──
    for subdir in ("sessions", "traces", "timeline", "index", "ratings", "pending", "locks"):
        p = data_dir() / subdir
        checks.append(check(f"{subdir}_dir", p.exists(), str(p)))
    # ── Runtime hook configurations ──
    claude_home = Path(os.environ.get("CLAUDE_HOME", str(Path.home() / ".claude")))
    codex_home = Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex")))
    claude_settings = claude_home / "settings.json"
    codex_hooks_json = codex_home / "hooks.json"
    codex_config = codex_home / "config.toml"
    # Claude hooks can be registered via settings.json OR via standalone hook scripts in hooks/
    claude_hook_ok = file_contains(claude_settings, "selftools") or file_contains(claude_settings, "aids")
    if not claude_hook_ok:
        for hname in ("selftools-session-start.sh", "selftools-pre-tool-use.sh", "selftools-post-tool-use.sh"):
            hp = claude_home / "hooks" / hname
            if hp.exists() and os.access(hp, os.X_OK):
                claude_hook_ok = True
                break
    checks.append(check("claude_settings", claude_hook_ok, str(claude_settings)))
    checks.append(check("codex_hooks", file_contains(codex_hooks_json, "selftools") or file_contains(codex_hooks_json, "aids"), str(codex_hooks_json)))
    checks.append(check("codex_mcp", file_contains(codex_config, "mcp_servers.selftools") or file_contains(codex_config, "mcp_servers.aids"), str(codex_config)))
    # ── Hook scripts executable ──
    for hook_name in ("selftools-session-start.sh", "selftools-pre-tool-use.sh", "selftools-post-tool-use.sh"):
        for home, label in ((claude_home, "claude"), (codex_home, "codex")):
            hp = home / "hooks" / hook_name
            ok_exec = hp.exists() and os.access(hp, os.X_OK)
            checks.append(check(f"{label}_hook_{hook_name}", ok_exec, str(hp)))
    # ── CLI symlinks valid ──
    bin_dir = Path(os.environ.get("AIDS_BIN_DIR", str(Path.home() / ".local" / "bin")))
    for name in ("aids", "aids-mcp", "aids-run"):
        link = bin_dir / name
        valid = link.is_symlink() and link.resolve().exists()
        checks.append(check(f"symlink_{name}", valid, f"{link} -> {link.resolve() if link.is_symlink() else 'missing'}"))
    # ── Lock mechanism ──
    lock_mech = "fcntl.flock" if fcntl is not None else "os.rename (portable)"
    checks.append(check("lock_mechanism", True, lock_mech))
    locks_dir = data_dir() / "locks"
    stale_count = sum(1 for _ in locks_dir.glob("*.lock")) if locks_dir.exists() else 0
    checks.append(check("stale_locks", stale_count == 0, f"{stale_count} lock files in {locks_dir}"))
    # ── config.json validity ──
    config_path = data_dir() / "config.json"
    config_ok = True
    if config_path.exists():
        try:
            json.loads(config_path.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, Exception):
            config_ok = False
    checks.append(check("config_json", config_ok, str(config_path)))
    # ── Protected config keys ──
    cfg = load_aids_config()
    for dotted, required in PROTECTED_CONFIG_KEYS.items():
        parts = dotted.split(".")
        obj = cfg
        for part in parts[:-1]:
            obj = obj.get(part, {}) if isinstance(obj, dict) else {}
        actual = obj.get(parts[-1]) if isinstance(obj, dict) else None
        safe = actual == required
        checks.append(check(f"config_protected_{dotted}", safe, f"{dotted}={'safe' if safe else f'VIOLATED: {actual!r}'}"))
    # ── Determine overall health ──
    critical_names = {"sessions_dir", "traces_dir", "claude_settings"}
    critical_ok = all(c["ok"] for c in checks if c["name"] in critical_names)
    all_ok = all(c["ok"] for c in checks)
    if args.json:
        print(json_dump({"ok": critical_ok, "all_ok": all_ok, "checks": checks}))
    else:
        print(f"{ZH_NAME} doctor")
        for c in checks:
            mark = "✅" if c["ok"] else "⚠️ "
            print(f"{mark} {c['name']}: {c['detail']}")
    # Self-reference: show current session identity
    sid = current_session_id()
    if sid:
        sess = load_session(sid)
        if sess:
            if not getattr(args, 'json', False):
                print(f"  Identity: {sess.get('display_name', sid)} (role={sess.get('role', '?')}, runtime={sess.get('runtime', '?')})")
    return 0 if critical_ok else 1


def check(name: str, ok: bool, detail: str) -> Dict[str, Any]:
    return {"name": name, "ok": bool(ok), "detail": detail}


def file_contains(path: Path, needle: str) -> bool:
    try:
        return needle in path.read_text(encoding="utf-8")
    except Exception:
        return False


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="aids", description="AIDS (Agent-ID System) identity-aware trace CLI")
    p.add_argument("--data-dir", help="Override ~/.aids data dir for this invocation")
    sub = p.add_subparsers(dest="cmd", required=True)

    hook = sub.add_parser("hook", help="Run hook handler")
    hook_sub = hook.add_subparsers(dest="hook_cmd", required=True)
    hook_sub.add_parser("session-start").set_defaults(func=cmd_hook_session_start)
    hook_sub.add_parser("pre-tool-use").set_defaults(func=cmd_hook_pre_tool_use)
    hook_sub.add_parser("post-tool-use").set_defaults(func=cmd_hook_post_tool_use)

    reg = sub.add_parser("register-session", help="Register/update a session identity")
    reg.add_argument("--session-id")
    reg.add_argument("--runtime", choices=["claude", "codex", "bash", "unknown"])
    reg.add_argument("--role")
    reg.add_argument("--goal")
    reg.add_argument("--display-name")
    reg.add_argument("--team-id")
    reg.add_argument("--task-id")
    reg.add_argument("--model")
    reg.add_argument("--cwd")
    reg.set_defaults(func=cmd_register_session)

    sess = sub.add_parser("session-info", help="Lookup a session")
    sess.add_argument("session_id")
    sess.add_argument("--json", action="store_true")
    sess.set_defaults(func=cmd_session_info)

    retire = sub.add_parser("retire-session", help="Mark a session as retired")
    retire.add_argument("session_id")
    retire.add_argument("--reason", help="Reason for retirement")
    retire.add_argument("--json", action="store_true")
    retire.set_defaults(func=cmd_retire_session)

    ls = sub.add_parser("list-sessions", help="List registered sessions")
    ls.add_argument("--status", choices=["active", "retired", "archived"], help="Filter by status")
    ls.add_argument("--role", help="Filter by role")
    ls.add_argument("--runtime", choices=["claude", "codex", "bash", "unknown"], help="Filter by runtime")
    ls.add_argument("--json", action="store_true")
    ls.set_defaults(func=cmd_list_sessions)

    hb = sub.add_parser("heartbeat", help="Bump session last_seen_at")
    hb.add_argument("session_id")
    hb.add_argument("--json", action="store_true")
    hb.set_defaults(func=cmd_heartbeat)

    wi = sub.add_parser("whois", help="Human-readable session summary")
    wi.add_argument("session_id")
    wi.add_argument("--json", action="store_true")
    wi.set_defaults(func=cmd_whois)

    wt = sub.add_parser("who-touched", help="Show recent operations for a file/resource")
    wt.add_argument("path")
    wt.add_argument("--limit", type=int, default=RECENT_LIMIT)
    wt.add_argument("--json", action="store_true")
    wt.add_argument("--sort", choices=["time", "operation", "agent"], default="time",
                    help="Sort traces by field (default: time)")
    wt.add_argument("--reverse", action="store_true", help="Reverse sort order")
    wt.set_defaults(func=cmd_who_touched)

    oc = sub.add_parser("op-chain", help="Show operation chain for a file/resource")
    oc.add_argument("path")
    oc.add_argument("--limit", type=int, default=50)
    oc.add_argument("--json", action="store_true")
    oc.set_defaults(func=cmd_op_chain)

    for q_name, q_help in [
        ("q", "Low-friction query router for files/traces/sessions"),
        ("query", "Query AIDS data with configurable resolver modules"),
        ("ask", "Natural-language query entrypoint (rule-based, no LLM)"),
    ]:
        qp = sub.add_parser(q_name, help=q_help)
        qp.add_argument("target", nargs="+", help="Target text, path, trace id, rating id, or session id")
        qp.add_argument("--json", action="store_true", help="JSON output")
        qp.add_argument("--full", action="store_true", help="Expand resolver details")
        qp.add_argument("--limit", type=int, help="Maximum items per resolver")
        qp.add_argument("--include", help="Comma-separated resolver modules to include")
        qp.add_argument("--exclude", help="Comma-separated resolver modules to exclude")
        qp.set_defaults(func=cmd_query)

    rate = sub.add_parser("rate", help="Rate a trace operation")
    rate.add_argument("trace_id")
    rate.add_argument("score", choices=["good", "bad", "neutral", "uncertain"])
    rate.add_argument("comment", nargs="*")
    rate.set_defaults(func=cmd_rate)


    tl = sub.add_parser("timeline", help="Show recent timeline events")
    tl.add_argument("--limit", type=int, default=20)
    tl.add_argument("--json", action="store_true")
    tl.set_defaults(func=cmd_timeline)

    stats = sub.add_parser("stats", help="Show aggregated statistics")
    stats.add_argument("--json", action="store_true", help="JSON output")
    stats.add_argument("--days", type=int, default=7, help="Lookback window in days (default: 7)")
    stats.add_argument("--all", action="store_true", dest="all", help="All time, ignore --days")
    stats.add_argument("--from", dest="from_date", help="Start date YYYY-MM-DD")
    stats.add_argument("--to", dest="to_date", help="End date YYYY-MM-DD")
    stats.set_defaults(func=cmd_stats)

    export = sub.add_parser("export", help="Export AIDS data")
    export.add_argument("--format", choices=["json", "jsonl", "csv"], default="json", help="Output format (default: json)")
    export.add_argument("--type", choices=["traces", "timeline", "ratings", "sessions", "all"], default="all", help="Data type to export (default: all)")
    export.add_argument("--output", help="Write to file instead of stdout")
    export.add_argument("--days", type=int, help="Lookback window in days (default: all time)")
    export.add_argument("--all", action="store_true", dest="all", help="All time, ignore --days")
    export.add_argument("--from", dest="from_date", help="Start date YYYY-MM-DD")
    export.add_argument("--to", dest="to_date", help="End date YYYY-MM-DD")
    export.add_argument("--session", help="Filter by session_id")
    export.add_argument("--resource", help="Filter by resource path")
    export.set_defaults(func=cmd_export)

    impact = sub.add_parser("impact", help="Show file impact analysis (dependents, risk, importance)")
    impact.add_argument("path", help="File path to analyze")
    impact.add_argument("--json", action="store_true", help="JSON output")
    impact.set_defaults(func=cmd_impact)

    cs = sub.add_parser("commit-stamp", help="Output git Co-Authored-By trailer with session identity")
    cs.set_defaults(func=cmd_commit_stamp)

    doctor = sub.add_parser("doctor", help="Verify installation")
    doctor.add_argument("--json", action="store_true")
    doctor.set_defaults(func=cmd_doctor)

    verify = sub.add_parser("verify", help="Verify trace integrity (chain hash + protected config)")
    verify.add_argument("trace_id", nargs="?", help="Specific trace ID to verify (default: verify all)")
    verify.add_argument("--json", action="store_true")
    verify.set_defaults(func=cmd_verify)
    return p


def main(argv: Optional[List[str]] = None) -> int:
    global DEFAULT_DATA_DIR
    parser = build_parser()
    args = parser.parse_args(argv)
    if getattr(args, "data_dir", None):
        DEFAULT_DATA_DIR = Path(args.data_dir).expanduser()
    try:
        return int(args.func(args))
    except BrokenPipeError:
        return 0
    except Exception as exc:
        append_log({"level": "error", "event": "cli_exception", "error": repr(exc), "session_id": current_session_id()})
        eprint_identity(f"aids error: {exc}")
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
