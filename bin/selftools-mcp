#!/usr/bin/env python3
"""Minimal STDIO MCP wrapper for AIDS (Agent-ID System).

This intentionally has no third-party dependencies. It exposes the query/rating
surface that the installer registers for Claude Code and Codex. Legacy
`selftools_*` tool names remain accepted as aliases.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any, Dict, List

ROOT = Path(__file__).resolve().parent
AIDS_CLI = str(ROOT / "selftools")  # implementation file; installed publicly as `aids`

TOOLS: List[Dict[str, Any]] = [
    {
        "name": "aids_who_touched",
        "description": "Show recent identity-aware operations for a file/resource.",
        "inputSchema": {
            "type": "object",
            "properties": {"path": {"type": "string"}, "limit": {"type": "integer", "default": 5}},
            "required": ["path"],
        },
    },
    {
        "name": "aids_session_info",
        "description": "Resolve an AIDS session id to runtime/role/goal metadata.",
        "inputSchema": {
            "type": "object",
            "properties": {"session_id": {"type": "string"}},
            "required": ["session_id"],
        },
    },
    {
        "name": "aids_op_chain",
        "description": "Show the operation chain for a file/resource.",
        "inputSchema": {
            "type": "object",
            "properties": {"path": {"type": "string"}, "limit": {"type": "integer", "default": 50}},
            "required": ["path"],
        },
    },
    {
        "name": "aids_rate",
        "description": "Rate an operation trace as good, bad, or uncertain with a comment.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "trace_id": {"type": "string"},
                "score": {"type": "string", "enum": ["good", "bad", "uncertain"]},
                "comment": {"type": "string"},
            },
            "required": ["trace_id", "score"],
        },
    },
    {
        "name": "aids_doctor",
        "description": "Check local AIDS installation health.",
        "inputSchema": {"type": "object", "properties": {}},
    },
]


def respond(msg_id: Any, result: Any = None, error: Any = None) -> None:
    if msg_id is None:
        return
    payload: Dict[str, Any] = {"jsonrpc": "2.0", "id": msg_id}
    if error is not None:
        payload["error"] = error
    else:
        payload["result"] = result
    print(json.dumps(payload, ensure_ascii=False), flush=True)


def text_result(text: str) -> Dict[str, Any]:
    return {"content": [{"type": "text", "text": text}], "isError": False}


def run_selftools(args: List[str]) -> str:
    env = os.environ.copy()
    proc = subprocess.run([AIDS_CLI] + args, text=True, capture_output=True, env=env)
    out = (proc.stdout or "") + (proc.stderr or "")
    if proc.returncode != 0 and not out.strip():
        out = f"aids exited with status {proc.returncode}"
    return out.strip()


def handle_tool(name: str, args: Dict[str, Any]) -> Dict[str, Any]:
    if name.startswith("selftools_"):
        name = "aids_" + name[len("selftools_"):]
    if name == "aids_who_touched":
        return text_result(run_selftools(["who-touched", str(args.get("path", "")), "--limit", str(args.get("limit", 5))]))
    if name == "aids_session_info":
        return text_result(run_selftools(["session-info", str(args.get("session_id", ""))]))
    if name == "aids_op_chain":
        return text_result(run_selftools(["op-chain", str(args.get("path", "")), "--limit", str(args.get("limit", 50))]))
    if name == "aids_rate":
        cmd = ["rate", str(args.get("trace_id", "")), str(args.get("score", "uncertain"))]
        if args.get("comment"):
            cmd.append(str(args["comment"]))
        return text_result(run_selftools(cmd))
    if name == "aids_doctor":
        return text_result(run_selftools(["doctor"]))
    raise ValueError(f"Unknown tool: {name}")


def main() -> int:
    for line in sys.stdin:
        if not line.strip():
            continue
        try:
            req = json.loads(line)
        except json.JSONDecodeError:
            continue
        msg_id = req.get("id")
        method = req.get("method")
        try:
            if method == "initialize":
                respond(
                    msg_id,
                    {
                        "protocolVersion": req.get("params", {}).get("protocolVersion", "2024-11-05"),
                        "capabilities": {"tools": {"listChanged": False}},
                        "serverInfo": {"name": "aids", "version": "0.1.0"},
                    },
                )
            elif method == "tools/list":
                respond(msg_id, {"tools": TOOLS})
            elif method == "tools/call":
                params = req.get("params") or {}
                respond(msg_id, handle_tool(str(params.get("name")), params.get("arguments") or {}))
            elif method in {"notifications/initialized", "$/cancelRequest"}:
                continue
            else:
                respond(msg_id, error={"code": -32601, "message": f"Method not found: {method}"})
        except Exception as exc:  # Keep MCP process alive.
            respond(msg_id, error={"code": -32000, "message": str(exc)})
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
