        },
        "satisfied": {
          "type": "boolean"
        },
        "lock_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "read_trace_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "read_timestamp": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "expires_at": {
          "type": [
