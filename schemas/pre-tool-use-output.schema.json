{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aids.local/schemas/pre-tool-use-output.schema.json",
  "title": "AIDS PreToolUse Output",
  "type": "object",
  "required": [
    "schema_version",
    "phase",
    "allow",
    "warnings",
    "awareness_message",
    "recent_traces",
    "required_read_before_write",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "const": "selftools.hook.v1"
    },
    "phase": {
      "const": "pre_tool_use"
    },
    "allow": {
      "type": "boolean"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "awareness_message": {
      "type": "string"
    },
    "recent_traces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "trace_id",
          "session_id",
          "tool",
          "resource_path",
          "operation",
          "intent",
          "timestamp"
        ],
        "properties": {
          "trace_id": {
            "type": "string",
            "minLength": 1
          },
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "tool": {
            "type": "string"
          },
          "resource_path": {
            "type": "string"
          },
          "operation": {
            "type": "string",
            "enum": [
              "create",
              "read",
              "modify",
              "delete",
              "execute",
              "touch",
              "unknown"
            ]
          },
          "intent": {
            "type": "string"
          },
          "pre_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "post_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "duration_ms": {
            "type": [
              "number",
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "timestamp": {
            "type": "integer",
            "minimum": 0
          },
          "timestamp_iso": {
            "type": [
              "string",
              "null"
            ]
          },
          "team_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "ratings_summary": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "required_read_before_write": {
      "type": "object",
      "required": [
        "required",
        "satisfied"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "satisfied": {
          "type": "boolean"
        },
        "lock_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "read_trace_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "read_timestamp": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "expires_at": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "observed_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": [
        "mode",
        "decision",
        "required_read_before_write"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "observe",
            "warn",
            "strict"
          ]
        },
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "warn",
            "block",
            "fail_open"
          ]
        },
        "required_read_before_write": {
          "type": "boolean"
        },
        "block_supported": {
          "type": "boolean"
        },
        "observation_lock": {
          "type": "object",
          "required": [
            "required",
            "satisfied"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "satisfied": {
              "type": "boolean"
            },
            "lock_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "read_trace_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "read_timestamp": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "expires_at": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "observed_hash": {
              "type": [
                "string",
                "null"
              ]
            },
            "current_hash": {
              "type": [
                "string",
                "null"
              ]
            },
            "reason": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "degradation_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "stdout_context": {
      "type": "string",
      "description": "Human-readable context safe to inject into Claude/Codex."
    },
    "stderr_warning": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
